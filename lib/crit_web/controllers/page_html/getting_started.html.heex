<div class="min-h-screen bg-(--crit-bg-primary) text-(--crit-fg-primary) font-sans antialiased">
  <Layouts.site_header current_user={@current_user} />
  <div class="max-w-7xl mx-auto mt-16 px-10 pb-20 max-sm:px-5 max-sm:pb-12">
    <%!-- Hero --%>
    <section class="mb-14 max-sm:mt-10 max-sm:mb-10">
      <p class="font-mono text-xs tracking-[0.2em] uppercase text-(--crit-accent) mb-3">
        Getting Started
      </p>
      <h1 class="text-4xl font-extrabold leading-[1.1] tracking-tight mb-4 max-sm:text-3xl">
        First review in<br />under a minute<span class="text-(--crit-accent)">.</span>
      </h1>
      <p class="text-base leading-relaxed text-(--crit-fg-secondary) max-w-[520px]">
        Install Crit, open a file, leave comments, hand off to your agent.
        No config, no login, no daemon.
      </p>
    </section>

    <%!-- Install --%>
    <section class="mb-16 max-sm:mb-12">
      <div class="flex items-baseline gap-4 mb-5">
        <span class="font-mono text-2xl font-bold text-(--crit-accent) leading-none select-none">
          01
        </span>
        <div>
          <h2 class="text-lg font-semibold tracking-tight">Install</h2>
          <p class="text-sm text-(--crit-fg-muted) mt-0.5">Single binary, zero dependencies.</p>
        </div>
      </div>
      <CritWeb.PageHTML.install_widget />
    </section>

    <%!-- Step 2: Open for review --%>
    <section class="mb-16 max-sm:mb-12">
      <div class="flex items-baseline gap-4 mb-5">
        <span class="font-mono text-2xl font-bold text-(--crit-accent) leading-none select-none">
          02
        </span>
        <div>
          <h2 class="text-lg font-semibold tracking-tight">Open a file for review</h2>
          <p class="text-sm text-(--crit-fg-muted) mt-0.5">
            Pass any file, or run
            <code class="text-xs bg-(--crit-bg-tertiary) px-1 py-0.5 rounded">crit</code>
            with no args to auto-detect changes in your repo.
          </p>
        </div>
      </div>

      <div class="border border-(--crit-border) rounded-lg overflow-hidden">
        <%!-- Terminal title bar --%>
        <div class="flex items-center gap-2 px-4 py-2.5 bg-(--crit-bg-tertiary) border-b border-(--crit-border)">
          <div class="flex gap-1.5">
            <div class="w-2.5 h-2.5 rounded-full bg-(--crit-fg-dimmed) opacity-40"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-(--crit-fg-dimmed) opacity-40"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-(--crit-fg-dimmed) opacity-40"></div>
          </div>
          <span class="font-mono text-xs text-(--crit-fg-muted) ml-2">Terminal</span>
        </div>
        <%!-- Terminal body --%>
        <div class="bg-(--crit-code-bg) p-6 font-mono text-sm leading-7 text-(--crit-fg-secondary)">
          <div>
            <span class="text-(--crit-fg-muted) select-none">$ </span><span class="text-(--crit-fg-primary)">crit plan.md</span>
          </div>
          <div class="mt-1">
            <span class="text-(--crit-fg-muted)"> Opening </span><span class="text-(--crit-accent)">plan.md</span><span class="text-(--crit-fg-muted)"> for review...</span>
          </div>
          <div>
            <span class="text-(--crit-fg-muted)"> Listening on </span><span class="text-(--crit-fg-primary)">http://localhost:3247</span>
          </div>
          <div class="mt-2 text-(--crit-fg-muted) text-xs">
            <%!-- Separator --%>
          </div>
          <div class="mt-1">
            <span class="text-(--crit-fg-muted) select-none">$ </span><span class="text-(--crit-fg-primary)">crit</span><span class="text-(--crit-fg-muted)"> # auto-detect changed files</span>
          </div>
          <div class="mt-1">
            <span class="text-(--crit-fg-muted)"> Found </span><span class="text-(--crit-accent)">3</span><span class="text-(--crit-fg-muted)"> changed files on branch </span><span class="text-(--crit-fg-primary)">feat/auth</span>
          </div>
          <div>
            <span class="text-(--crit-fg-muted)"> Listening on </span><span class="text-(--crit-fg-primary)">http://localhost:3247</span>
          </div>
        </div>
      </div>

      <p class="text-sm text-(--crit-fg-muted) mt-3 leading-relaxed">
        Your browser opens automatically. Markdown files render as documents. Code files show
        syntax-highlighted source with line numbers.
      </p>
    </section>

    <%!-- Step 3: Leave comments --%>
    <section class="mb-16 max-sm:mb-12">
      <div class="flex items-baseline gap-4 mb-5">
        <span class="font-mono text-2xl font-bold text-(--crit-accent) leading-none select-none">
          03
        </span>
        <div>
          <h2 class="text-lg font-semibold tracking-tight">Leave inline comments</h2>
          <p class="text-sm text-(--crit-fg-muted) mt-0.5">
            Click a line number or drag across a range. GitHub-style review UI.
          </p>
        </div>
      </div>

      <%!-- Mock review UI --%>
      <div class="border border-(--crit-border) rounded-lg overflow-hidden bg-(--crit-bg-secondary)">
        <%!-- File header bar --%>
        <div class="flex items-center gap-2 px-4 py-2.5 border-b border-(--crit-border) bg-(--crit-bg-tertiary)">
          <span class="font-mono text-xs font-semibold text-(--crit-fg-secondary)">
            Crit
          </span>
          <span class="text-(--crit-fg-dimmed) text-xs">/</span>
          <span class="font-mono text-xs text-(--crit-fg-muted) bg-(--crit-bg-secondary) px-2 py-0.5 rounded">
            plan.md
          </span>
          <div class="ml-auto flex items-center gap-3">
            <span class="font-mono text-xs text-(--crit-fg-muted)">
              <strong class="text-(--crit-accent)">1</strong> comment
            </span>
          </div>
        </div>

        <%!-- Document lines --%>
        <div class="font-mono text-xs leading-6 select-none">
          <div class="flex border-l-[3px] border-transparent">
            <div class="w-[42px] shrink-0 text-right pr-3 py-0.5 text-(--crit-fg-dimmed)">1</div>
            <div class="flex-1 px-3 py-0.5 font-sans font-bold text-sm text-(--crit-fg-primary)">
              # Add rate limiting
            </div>
          </div>
          <div class="flex border-l-[3px] border-transparent">
            <div class="w-[42px] shrink-0 text-right pr-3 py-0.5 text-(--crit-fg-dimmed)">2</div>
            <div class="flex-1 px-3 py-0.5">&nbsp;</div>
          </div>
          <div class="flex border-l-[3px] border-(--crit-accent) bg-(--crit-accent-subtle)">
            <div class="w-[42px] shrink-0 text-right pr-3 py-0.5 text-(--crit-accent)">3</div>
            <div class="flex-1 px-3 py-0.5 font-sans text-xs text-(--crit-fg-secondary)">
              Apply a global rate limit of 100 req/s per IP.
            </div>
          </div>
          <div class="flex border-l-[3px] border-(--crit-accent) bg-(--crit-accent-subtle)">
            <div class="w-[42px] shrink-0 text-right pr-3 py-0.5 text-(--crit-accent)">4</div>
            <div class="flex-1 px-3 py-0.5 font-sans text-xs text-(--crit-fg-secondary)">
              Use a fixed window counter stored in Redis.
            </div>
          </div>
          <%!-- Comment --%>
          <div class="mx-3 mb-1 mt-0.5 border border-(--crit-border-comment) rounded text-xs overflow-hidden bg-(--crit-comment-bg)">
            <div class="px-3 py-1.5 border-b border-(--crit-border) flex items-center gap-2 bg-(--crit-accent-subtle)">
              <span class="font-sans font-semibold text-(--crit-accent)">You</span>
              <span class="text-(--crit-fg-dimmed)">&middot;</span>
              <span class="font-sans text-(--crit-fg-muted)">Lines 3-4</span>
            </div>
            <div class="px-3 py-2 font-sans text-(--crit-fg-secondary) leading-relaxed">
              100 req/s is too aggressive for our API. Start with 1000 and add per-endpoint limits later. Also, token bucket > fixed window for bursty traffic.
            </div>
          </div>
          <div class="flex border-l-[3px] border-transparent">
            <div class="w-[42px] shrink-0 text-right pr-3 py-0.5 text-(--crit-fg-dimmed)">5</div>
            <div class="flex-1 px-3 py-0.5 font-sans text-xs text-(--crit-fg-secondary)">
              Return 429 with a Retry-After header.
            </div>
          </div>
          <div class="flex border-l-[3px] border-transparent">
            <div class="w-[42px] shrink-0 text-right pr-3 py-0.5 text-(--crit-fg-dimmed)">6</div>
            <div class="flex-1 px-3 py-0.5 font-sans text-xs text-(--crit-fg-secondary)">
              Log blocked requests to stdout.
            </div>
          </div>
        </div>
      </div>

      <div class="flex flex-wrap gap-x-6 gap-y-2 mt-4 text-sm text-(--crit-fg-muted)">
        <span class="flex items-center gap-1.5">
          <kbd class="inline-flex items-center justify-center font-mono text-xs min-w-[20px] h-5 px-1.5 rounded border border-(--crit-border) bg-(--crit-bg-tertiary) text-(--crit-fg-secondary)">
            j
          </kbd>
          <kbd class="inline-flex items-center justify-center font-mono text-xs min-w-[20px] h-5 px-1.5 rounded border border-(--crit-border) bg-(--crit-bg-tertiary) text-(--crit-fg-secondary)">
            k
          </kbd>
          navigate
        </span>
        <span class="flex items-center gap-1.5">
          <kbd class="inline-flex items-center justify-center font-mono text-xs min-w-[20px] h-5 px-1.5 rounded border border-(--crit-border) bg-(--crit-bg-tertiary) text-(--crit-fg-secondary)">
            c
          </kbd>
          comment
        </span>
        <span class="flex items-center gap-1.5">
          <kbd class="inline-flex items-center justify-center font-mono text-xs min-w-[20px] h-5 px-1.5 rounded border border-(--crit-border) bg-(--crit-bg-tertiary) text-(--crit-fg-secondary)">
            ?
          </kbd>
          all shortcuts
        </span>
      </div>
    </section>

    <%!-- Step 4: Hand off and iterate --%>
    <section class="mb-16 max-sm:mb-12">
      <div class="flex items-baseline gap-4 mb-5">
        <span class="font-mono text-2xl font-bold text-(--crit-accent) leading-none select-none">
          04
        </span>
        <div>
          <h2 class="text-lg font-semibold tracking-tight">Finish review and hand off</h2>
          <p class="text-sm text-(--crit-fg-muted) mt-0.5">
            Click <strong class="text-(--crit-fg-secondary)">Finish Review</strong>. A structured prompt is copied to your clipboard &mdash; paste it back to your agent.
          </p>
        </div>
      </div>

      <div class="border border-(--crit-border) rounded-lg overflow-hidden">
        <div class="flex items-center gap-2 px-4 py-2.5 bg-(--crit-bg-tertiary) border-b border-(--crit-border)">
          <div class="flex gap-1.5">
            <div class="w-2.5 h-2.5 rounded-full bg-(--crit-fg-dimmed) opacity-40"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-(--crit-fg-dimmed) opacity-40"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-(--crit-fg-dimmed) opacity-40"></div>
          </div>
          <span class="font-mono text-xs text-(--crit-fg-muted) ml-2">Crit</span>
        </div>
        <div class="bg-(--crit-code-bg) p-6 font-mono text-sm leading-7 text-(--crit-fg-secondary)">
          <div>
            <span class="text-(--crit-accent)">&rarr;</span>
            Round 1: <span class="text-(--crit-accent)">2</span>
            comments added
          </div>
          <div>
            <span class="text-(--crit-green)">&rarr;</span>
            Finish review &mdash; prompt copied <span class="text-(--crit-green)">&check;</span>
          </div>
          <div class="text-(--crit-fg-muted)">
            &nbsp; Paste into your agent, it reads .crit.json&hellip;
          </div>
          <div class="mt-2">
            <span class="text-(--crit-green)">&rarr;</span>
            File updated (<span class="text-(--crit-accent)">5</span> edits detected)
          </div>
          <div>
            <span class="text-(--crit-accent)">&rarr;</span>
            Round 2: diff ready &mdash; <span class="text-(--crit-green)">2 resolved</span>
          </div>
          <div class="text-(--crit-fg-muted)">
            &nbsp; Review the diff, leave more comments, or approve.
          </div>
        </div>
      </div>

      <p class="text-sm text-(--crit-fg-muted) mt-4 leading-relaxed">
        The agent reads <code class="text-xs bg-(--crit-bg-tertiary) px-1 py-0.5 rounded">.crit.json</code>, addresses your comments, and runs
        <code class="text-xs bg-(--crit-bg-tertiary) px-1 py-0.5 rounded">crit go</code>
        when done. Crit reloads with a diff of what changed. Repeat until you're satisfied.
      </p>
      <p class="text-sm text-(--crit-fg-muted) mt-2 leading-relaxed">
        With an <a
          href={~p"/integrations"}
          class="text-(--crit-accent) no-underline hover:underline"
        >agent integration</a>, this loop is fully automatic &mdash; the agent listens for your review and iterates without manual copy-paste.
      </p>
    </section>

    <%!-- Connect your agent --%>
    <section class="mb-16 max-sm:mb-12">
      <div class="flex items-baseline gap-4 mb-5">
        <span class="font-mono text-2xl font-bold text-(--crit-accent) leading-none select-none">
          05
        </span>
        <div>
          <h2 class="text-lg font-semibold tracking-tight">Automate with your agent</h2>
          <p class="text-sm text-(--crit-fg-muted) mt-0.5">
            Install a slash command so your agent handles the full loop &mdash; launching Crit, listening for your review, and iterating automatically.
          </p>
        </div>
      </div>

      <%!-- Install terminal --%>
      <div class="border border-(--crit-border) rounded-lg overflow-hidden">
        <div class="flex items-center gap-2 px-4 py-2.5 bg-(--crit-bg-tertiary) border-b border-(--crit-border)">
          <div class="flex gap-1.5">
            <div class="w-2.5 h-2.5 rounded-full bg-(--crit-fg-dimmed) opacity-40"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-(--crit-fg-dimmed) opacity-40"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-(--crit-fg-dimmed) opacity-40"></div>
          </div>
          <span class="font-mono text-xs text-(--crit-fg-muted) ml-2">Terminal</span>
        </div>
        <div class="bg-(--crit-code-bg) p-6 font-mono text-sm leading-7 text-(--crit-fg-secondary)">
          <div>
            <span class="text-(--crit-fg-muted) select-none">$ </span><span class="text-(--crit-fg-primary)">crit install claude-code</span>
          </div>
          <div>
            <span class="text-(--crit-green)">&check;</span>
            <span class="text-(--crit-fg-muted)"> Installed</span> .claude/skills/crit/SKILL.md
          </div>
        </div>
      </div>

      <%!-- Then use the slash command --%>
      <div class="border border-(--crit-border) rounded-lg overflow-hidden mt-3">
        <div class="flex items-center gap-2 px-4 py-2.5 bg-(--crit-bg-tertiary) border-b border-(--crit-border)">
          <div class="flex gap-1.5">
            <div class="w-2.5 h-2.5 rounded-full bg-(--crit-fg-dimmed) opacity-40"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-(--crit-fg-dimmed) opacity-40"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-(--crit-fg-dimmed) opacity-40"></div>
          </div>
          <span class="font-mono text-xs text-(--crit-fg-muted) ml-2">Claude Code</span>
        </div>
        <div class="bg-(--crit-code-bg) p-6 font-mono text-sm leading-7 text-(--crit-fg-secondary)">
          <div>
            <span class="text-(--crit-accent) select-none">&gt; </span><span class="text-(--crit-fg-primary)">/crit</span>
          </div>
          <div class="text-(--crit-fg-muted)">&nbsp; Opening plan.md for review&hellip;</div>
          <div class="text-(--crit-fg-muted)">&nbsp; Listening for your comments&hellip;</div>
          <div class="mt-1">
            <span class="text-(--crit-green)">&rarr;</span>
            Review received &mdash; addressing 2 comments
          </div>
          <div class="text-(--crit-fg-muted)">&nbsp; Running crit go&hellip;</div>
          <div>
            <span class="text-(--crit-accent)">&rarr;</span> Round 2 ready for review
          </div>
        </div>
      </div>

      <div class="flex flex-wrap gap-2 mt-4">
        <span class="inline-flex items-center gap-1.5 text-xs font-mono border border-(--crit-border) rounded-md px-2.5 py-1.5 text-(--crit-fg-secondary) bg-(--crit-bg-secondary)">
          Claude Code
        </span>
        <span class="inline-flex items-center gap-1.5 text-xs font-mono border border-(--crit-border) rounded-md px-2.5 py-1.5 text-(--crit-fg-secondary) bg-(--crit-bg-secondary)">
          Cursor
        </span>
        <span class="inline-flex items-center gap-1.5 text-xs font-mono border border-(--crit-border) rounded-md px-2.5 py-1.5 text-(--crit-fg-secondary) bg-(--crit-bg-secondary)">
          GitHub Copilot
        </span>
        <span class="inline-flex items-center gap-1.5 text-xs font-mono border border-(--crit-border) rounded-md px-2.5 py-1.5 text-(--crit-fg-secondary) bg-(--crit-bg-secondary)">
          Windsurf
        </span>
        <span class="inline-flex items-center gap-1.5 text-xs font-mono border border-(--crit-border) rounded-md px-2.5 py-1.5 text-(--crit-fg-secondary) bg-(--crit-bg-secondary)">
          Aider
        </span>
        <span class="inline-flex items-center gap-1.5 text-xs font-mono border border-(--crit-border) rounded-md px-2.5 py-1.5 text-(--crit-fg-secondary) bg-(--crit-bg-secondary)">
          Cline
        </span>
      </div>

      <p class="text-sm text-(--crit-fg-muted) mt-3">
        See all config files and setup instructions on the <a
          href={~p"/integrations"}
          class="text-(--crit-accent) no-underline hover:underline"
        >integrations page</a>.
      </p>
    </section>

    <%!-- What's next --%>
    <section>
      <p class="font-mono text-xs tracking-[0.2em] uppercase text-(--crit-accent) mb-3">
        What's next
      </p>
      <h2 class="text-2xl font-extrabold tracking-tight mb-6 max-sm:text-xl">
        Go deeper<span class="text-(--crit-accent)">.</span>
      </h2>

      <div class="grid grid-cols-3 gap-3 max-sm:grid-cols-1">
        <a
          href={~p"/features"}
          class="border border-(--crit-border) rounded-lg bg-(--crit-bg-secondary) p-6 no-underline text-inherit hover:border-(--crit-fg-dimmed) transition-[border-color] duration-150 flex flex-col"
        >
          <h3 class="text-sm font-semibold mb-1.5">All features</h3>
          <p class="text-xs text-(--crit-fg-muted) leading-relaxed flex-1">
            Diffs, vim keybindings, mermaid diagrams, syntax highlighting, and more.
          </p>
          <span class="text-xs text-(--crit-accent) mt-3">Explore &rarr;</span>
        </a>

        <a
          href={~p"/features/share-reviews"}
          class="border border-(--crit-border) rounded-lg bg-(--crit-bg-secondary) p-6 no-underline text-inherit hover:border-(--crit-fg-dimmed) transition-[border-color] duration-150 flex flex-col"
        >
          <h3 class="text-sm font-semibold mb-1.5">Share reviews</h3>
          <p class="text-xs text-(--crit-fg-muted) leading-relaxed flex-1">
            One click to generate a public link. Get a second opinion before handing off.
          </p>
          <span class="text-xs text-(--crit-accent) mt-3">Learn more &rarr;</span>
        </a>

        <a
          href={~p"/self-hosting"}
          class="border border-(--crit-border) rounded-lg bg-(--crit-bg-secondary) p-6 no-underline text-inherit hover:border-(--crit-fg-dimmed) transition-[border-color] duration-150 flex flex-col"
        >
          <h3 class="text-sm font-semibold mb-1.5">Self-host</h3>
          <p class="text-xs text-(--crit-fg-muted) leading-relaxed flex-1">
            Run your own Crit Web instance with Docker. Share reviews on your own infrastructure.
          </p>
          <span class="text-xs text-(--crit-accent) mt-3">Set up &rarr;</span>
        </a>
      </div>
    </section>
  </div>
</div>
