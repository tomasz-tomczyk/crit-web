<Layouts.flash_group flash={@flash} />

<div class="min-h-screen bg-(--crit-bg-primary) text-(--crit-fg-primary) font-sans flex flex-col">
  <Layouts.site_header current_user={@current_user} />
  
<!-- Breadcrumb -->
  <div class="max-w-[1100px] mx-auto w-full px-10 mt-8 max-sm:px-5 max-sm:mt-5">
    <a
      href={~p"/"}
      class="text-sm text-(--crit-fg-muted) no-underline hover:text-(--crit-fg-primary) transition-colors"
    >
      &larr; Back to Crit
    </a>
  </div>
  
<!-- Hero -->
  <section class="max-w-[1100px] mx-auto w-full px-10 mt-6 max-sm:px-5">
    <p class="font-mono text-xs tracking-widest uppercase text-(--crit-accent) mb-3">
      Integrations
    </p>
    <h1 class="text-4xl font-bold leading-tight tracking-tighter mb-4 max-sm:text-3xl">
      Connect Crit to your agent<span class="text-(--crit-accent)">.</span>
    </h1>
    <p class="text-lg text-(--crit-fg-secondary) leading-relaxed max-w-[640px]">
      Drop one file into your project. Your agent writes a plan, launches Crit for review,
      and waits for your feedback before writing code. The same integration works for reviewing
      code changes after your agent writes them.
    </p>
  </section>
  
<!-- Tabbed integrations -->
  <section class="max-w-[1100px] mx-auto w-full px-10 mt-10 mb-16 max-sm:px-5 max-sm:mt-8">
    <!-- Tab bar -->
    <div class="flex gap-0 border-b border-(--crit-border) overflow-x-auto">
      <%= for {integration, idx} <- Enum.with_index(@integrations) do %>
        <button
          class={"integration-tab font-mono text-sm px-4 py-2 -mb-px border-b-2 transition-colors cursor-pointer bg-transparent whitespace-nowrap #{if idx == 0, do: "border-(--crit-accent) text-(--crit-accent)", else: "border-transparent text-(--crit-fg-muted) hover:text-(--crit-fg-secondary)"}"}
          data-target={"integration-#{integration.id}"}
        >
          {integration.name}
        </button>
      <% end %>
    </div>
    
<!-- Panels -->
    <%= for {integration, idx} <- Enum.with_index(@integrations) do %>
      <div
        id={"integration-#{integration.id}"}
        class={"integration-panel #{if idx != 0, do: "hidden"}"}
      >
        <div class="mt-6 mb-4">
          <p class="text-sm text-(--crit-fg-secondary) leading-relaxed mb-2">
            {integration.description}
          </p>
          <p class="font-mono text-xs text-(--crit-fg-muted)">
            Copy to
            <code class="text-(--crit-accent) bg-(--crit-bg-tertiary) px-1.5 py-0.5 rounded">
              {integration.file_path}
            </code>
          </p>
        </div>
        
<!-- Snippet -->
        <div class="border border-(--crit-border) rounded-md overflow-hidden">
          <div class="flex items-center justify-between px-4 py-2 bg-(--crit-bg-tertiary) border-b border-(--crit-border)">
            <span class="font-mono text-xs text-(--crit-fg-muted)">{integration.file_path}</span>
            <button
              class="copy-snippet-btn shrink-0 px-3 py-1 text-xs font-mono text-(--crit-fg-muted) hover:text-(--crit-fg-primary) cursor-pointer bg-transparent border border-(--crit-border) rounded transition-colors"
              data-snippet={"snippet-#{integration.id}"}
            >
              Copy
            </button>
          </div>
          <pre
            id={"snippet-#{integration.id}"}
            class="m-0 px-5 py-4 text-xs font-mono leading-6 text-(--crit-fg-secondary) bg-(--crit-code-bg) overflow-x-auto whitespace-pre-wrap"
          >{String.trim(integration.snippet)}</pre>
        </div>
        
<!-- Secondary snippet (Claude Code only) -->
        <%= if Map.has_key?(integration, :secondary_snippet) do %>
          <div class="mt-8 mb-4">
            <p class="text-sm font-semibold text-(--crit-fg-primary) mb-1">
              {integration.secondary_label}
            </p>
            <p class="font-mono text-xs text-(--crit-fg-muted)">
              {integration.secondary_file_path}
            </p>
          </div>

          <div class="border border-(--crit-border) rounded-md overflow-hidden">
            <div class="flex items-center justify-between px-4 py-2 bg-(--crit-bg-tertiary) border-b border-(--crit-border)">
              <span class="font-mono text-xs text-(--crit-fg-muted)">CLAUDE.md</span>
              <button
                class="copy-snippet-btn shrink-0 px-3 py-1 text-xs font-mono text-(--crit-fg-muted) hover:text-(--crit-fg-primary) cursor-pointer bg-transparent border border-(--crit-border) rounded transition-colors"
                data-snippet={"snippet-#{integration.id}-secondary"}
              >
                Copy
              </button>
            </div>
            <pre
              id={"snippet-#{integration.id}-secondary"}
              class="m-0 px-5 py-4 text-xs font-mono leading-6 text-(--crit-fg-secondary) bg-(--crit-code-bg) overflow-x-auto whitespace-pre-wrap"
            >{String.trim(integration.secondary_snippet)}</pre>
          </div>
        <% end %>
      </div>
    <% end %>
    
<!-- GitHub link -->
    <div class="mt-8 text-center">
      <a
        href="https://github.com/tomasz-tomczyk/crit/tree/main/integrations"
        class="text-sm text-(--crit-accent) no-underline hover:underline"
      >
        View all integration files on GitHub &rarr;
      </a>
    </div>
  </section>
</div>
