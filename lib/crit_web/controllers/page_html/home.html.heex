<Layouts.flash_group flash={@flash} />

<div class="min-h-screen bg-(--crit-bg-primary) text-(--crit-fg-primary) font-sans flex flex-col">
  <Layouts.site_header current_user={@current_user} />

  <section class="max-w-7xl mx-auto pt-24 pb-16 px-10 w-full max-sm:px-5 max-sm:pt-14 max-sm:pb-10">
    <div class="text-center max-w-3xl mx-auto mb-14 max-sm:mb-10">
      <p class="font-mono text-xs tracking-[0.2em] uppercase text-(--crit-accent) mb-5">
        Local-first · No login · Works with any agent
      </p>
      <h1 class="text-[4.5rem] font-extrabold leading-[1.02] tracking-[-0.035em] mb-7 max-lg:text-6xl max-sm:text-[2.75rem]">
        Your feedback loop<br />with the
        <span class="whitespace-nowrap">
          agent<span class="text-(--crit-accent)">.</span>
          <span class="crit-blink-cursor">
            ▍
          </span>
        </span>
      </h1>
      <p class="text-xl max-sm:text-base leading-relaxed text-(--crit-fg-secondary) max-w-2xl mx-auto mb-10">
        Review plans before your agent writes code. Review code before you ship it.
        Leave inline comments, click Finish Review, and your agent
        picks up the feedback automatically.
      </p>
      <div class="flex gap-3 justify-center flex-wrap max-sm:grid max-sm:grid-cols-2">
        <a
          href={~p"/getting-started"}
          class="inline-flex items-center justify-center px-7 py-3 bg-(--crit-accent) text-(--crit-bg-primary) rounded-lg text-sm font-bold no-underline hover:bg-(--crit-accent-hover) transition-colors"
        >
          Get started
        </a>
        <%= if @demo_token do %>
          <a
            href={~p"/r/#{@demo_token}"}
            class="inline-flex items-center justify-center px-7 py-3 border border-(--crit-border) text-(--crit-fg-secondary) rounded-lg text-sm font-semibold no-underline hover:border-(--crit-fg-muted) hover:text-(--crit-fg-primary) transition-colors"
          >
            See demo
          </a>
        <% end %>
        <a
          href="https://github.com/tomasz-tomczyk/crit"
          class="inline-flex items-center justify-center gap-2 px-7 py-3 border border-(--crit-border) text-(--crit-fg-secondary) rounded-lg text-sm font-semibold no-underline hover:border-(--crit-fg-muted) hover:text-(--crit-fg-primary) transition-colors max-sm:col-span-2"
        >
          <svg viewBox="0 0 16 16" class="size-3.5 fill-current opacity-70" aria-hidden="true">
            <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z" />
          </svg>
          Star on GitHub
        </a>
      </div>
    </div>

    <div
      class="relative w-full rounded-xl overflow-hidden border border-(--crit-border) cursor-pointer group"
      style="aspect-ratio: 16/9;"
      id="yt-facade"
      aria-label="Play Crit demo video"
      role="button"
      tabindex="0"
    >
      <img
        src="https://i.ytimg.com/vi/w_Dswm2Ft-o/maxresdefault.jpg"
        alt="Crit demo video thumbnail"
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 flex items-center justify-center bg-black/20 group-hover:bg-black/40 transition-colors">
        <svg viewBox="0 0 68 48" class="w-[68px] h-[48px] drop-shadow-lg" aria-hidden="true">
          <path
            d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55C3.97 2.33 2.27 4.81 1.48 7.74.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z"
            fill="#f00"
          />
          <path d="M45 24 27 14v20" fill="#fff" />
        </svg>
      </div>
    </div>
    <p class="text-sm text-(--crit-fg-muted) mt-6 text-center">
      Works with Claude Code, Cursor, GitHub Copilot, Aider, Cline, Windsurf, or any agent that reads files.
      <a href={~p"/integrations"} class="text-(--crit-accent) no-underline hover:underline">
        Set up your agent &rarr;
      </a>
    </p>
  </section>

<!-- ===== Install ===== -->
  <section class="max-w-7xl mx-auto mt-24 px-10 max-sm:px-5 max-sm:mt-16 w-full" id="install">
    <div class="flex gap-14 items-start max-lg:flex-col max-lg:gap-6">
      <div class="w-[300px] shrink-0 max-lg:w-full">
        <p class="font-mono text-xs tracking-[0.2em] uppercase text-(--crit-accent) mb-3">
          Quick start
        </p>
        <h2 class="text-2xl font-extrabold tracking-tight mb-3">Install</h2>
        <p class="text-sm text-(--crit-fg-secondary) leading-relaxed">
          Single binary, zero dependencies. Pick your package manager and start reviewing in seconds.
        </p>
      </div>
      <div class="flex-1 min-w-0 max-lg:w-full">
        <CritWeb.PageHTML.install_widget />
      </div>
    </div>
  </section>
  
<!-- ===== Features ===== -->
  <section
    class="max-w-7xl mx-auto mt-28 mb-20 px-10 max-sm:px-5 max-sm:mt-16 w-full"
    id="features"
  >
    <p class="font-mono text-xs tracking-[0.2em] uppercase text-(--crit-accent) mb-4">
      Features
    </p>
    <h2 class="text-4xl font-extrabold tracking-tight mb-12 max-sm:text-2xl max-sm:mb-8">
      Built for the feedback loop<span class="text-(--crit-accent) ">.</span>
    </h2>

    <div class="grid grid-cols-3 gap-5 max-lg:grid-cols-2 max-sm:grid-cols-1" id="features-grid">
      
<!-- Inline Comments -->
      <a
        href={~p"/features/inline-comments"}
        class="feature-card col-span-2 max-lg:col-span-1 border border-(--crit-border) rounded-lg bg-(--crit-bg-secondary) p-6 flex flex-col gap-4 hover:border-(--crit-fg-dimmed) transition-[border-color] duration-150 no-underline text-inherit"
      >
        <div>
          <h3 class="text-base font-semibold tracking-tight mb-1">Inline Comments</h3>
          <p class="text-sm text-(--crit-fg-secondary) leading-relaxed">
            Click and drag line numbers to select ranges. Leave PR-style inline comments on any block.
          </p>
        </div>
        <div
          class="rounded-md border border-(--crit-border) bg-(--crit-bg-primary) overflow-hidden text-xs font-mono leading-5 select-none"
          aria-hidden="true"
        >
          <div class="flex">
            <span class="w-7 text-right pr-2 py-px text-(--crit-fg-dimmed) shrink-0">3</span>
            <span class="flex-1 px-2 py-px text-(--crit-fg-primary) font-sans font-semibold text-xs">
              ## Backend
            </span>
          </div>
          <div class="flex border-l-2 border-(--crit-accent) bg-(--crit-accent-subtle)">
            <span class="w-7 text-right pr-2 py-px text-(--crit-accent)  shrink-0">4</span>
            <span class="flex-1 px-2 py-px text-(--crit-fg-secondary) font-sans">
              Use JWT tokens for sessions.
            </span>
          </div>
          <div class="ml-7 mr-2 my-1 border border-(--crit-border-comment) rounded text-xs bg-(--crit-comment-bg) overflow-hidden">
            <div class="px-2 py-1 bg-(--crit-accent-subtle) border-b border-(--crit-border) font-sans flex items-center gap-1.5">
              <span class="text-(--crit-accent)  font-semibold">You</span>
              <span class="text-(--crit-fg-dimmed)">&middot;</span>
              <span class="text-(--crit-fg-muted)">Line 4</span>
            </div>
            <div class="px-2 py-1.5 text-(--crit-fg-secondary) font-sans">
              Consider OAuth2 instead - simpler for users.
            </div>
          </div>
          <div class="flex">
            <span class="w-7 text-right pr-2 py-px text-(--crit-fg-dimmed) shrink-0">5</span>
            <span class="flex-1 px-2 py-px text-(--crit-fg-secondary) font-sans">
              Rate limit all endpoints.
            </span>
          </div>
        </div>
      </a>
      
<!-- Diff Viewer -->
      <a
        href={~p"/features/split-unified-diff"}
        class="feature-card border border-(--crit-border) rounded-lg bg-(--crit-bg-secondary) p-6 flex flex-col gap-4 hover:border-(--crit-fg-dimmed) transition-[border-color] duration-150 no-underline text-inherit"
      >
        <div>
          <h3 class="text-base font-semibold tracking-tight mb-1">Git Diffs & Round Diffs</h3>
          <p class="text-sm text-(--crit-fg-secondary) leading-relaxed">
            Review code as git diffs. See what changed between rounds. Split or unified views.
          </p>
        </div>
        <div
          class="rounded-md border border-(--crit-border) overflow-hidden text-xs font-mono leading-4 select-none"
          aria-hidden="true"
        >
          <div class="grid grid-cols-2">
            <div class="px-2 py-1 bg-(--crit-bg-tertiary) text-(--crit-fg-muted) border-b border-r border-(--crit-border) font-sans font-semibold text-xs">
              Previous
            </div>
            <div class="px-2 py-1 bg-(--crit-bg-tertiary) text-(--crit-fg-muted) border-b border-(--crit-border) font-sans font-semibold text-xs">
              Current
            </div>
          </div>
          <div class="grid grid-cols-2">
            <div class="px-2 py-0.5 bg-(--crit-bg-primary) text-(--crit-fg-secondary) border-r border-(--crit-border)">
              Use JWT tokens
            </div>
            <div class="px-2 py-0.5 bg-(--crit-bg-primary) text-(--crit-fg-secondary)">
              Use JWT tokens
            </div>
          </div>
          <div class="grid grid-cols-2">
            <div class="px-2 py-0.5 diff-removed-bg text-(--crit-red) line-through opacity-70 border-r border-(--crit-border)">
              bcrypt hashing
            </div>
            <div class="px-2 py-0.5 diff-added-bg text-(--crit-green)">argon2id hashing</div>
          </div>
          <div class="grid grid-cols-2">
            <div class="px-2 py-0.5 bg-(--crit-bg-primary) text-(--crit-fg-secondary) border-r border-(--crit-border)">
              Rate limit all
            </div>
            <div class="px-2 py-0.5 bg-(--crit-bg-primary) text-(--crit-fg-secondary)">
              Rate limit all
            </div>
          </div>
          <div class="grid grid-cols-2">
            <div class="px-2 py-0.5 bg-(--crit-bg-primary) border-r border-(--crit-border)">
              &nbsp;
            </div>
            <div class="px-2 py-0.5 diff-added-bg text-(--crit-green)">
              + Add CORS headers
            </div>
          </div>
        </div>
      </a>
      
<!-- AI Review Loop -->
      <a
        href={~p"/features/ai-review-loop"}
        class="feature-card col-span-2 max-sm:col-span-1 border border-(--crit-border) rounded-lg bg-(--crit-bg-secondary) p-6 flex flex-col gap-4 hover:border-(--crit-fg-dimmed) transition-[border-color] duration-150 no-underline text-inherit"
      >
        <div>
          <h3 class="text-base font-semibold tracking-tight mb-1">AI Review Loop</h3>
          <p class="text-sm text-(--crit-fg-secondary) leading-relaxed">
            Leave comments, click finish, and your agent picks up the feedback automatically. It edits the file. Crit reloads with a diff of what changed. Previous comments stay visible so nothing gets skipped.
          </p>
        </div>
        <div
          class="rounded-md border border-(--crit-border) bg-(--crit-code-bg) p-3 text-xs font-mono leading-5 text-(--crit-fg-secondary) select-none"
          aria-hidden="true"
        >
          <div><span class="text-(--crit-fg-muted)">$</span> crit</div>
          <div class="text-(--crit-fg-muted)">&nbsp; Listening on http://localhost:3247</div>
          <div>
            <span class="text-(--crit-accent) ">&rarr;</span>
            Round 1: <span class="text-(--crit-accent) ">3</span>
            comments added
          </div>
          <div>
            <span class="text-(--crit-green)">&rarr;</span>
            Finish review - agent notified <span class="text-(--crit-green)">&check;</span>
          </div>
          <div>
            <span class="text-(--crit-fg-muted)">&rarr;</span> Agent working&hellip;
          </div>
          <div>
            <span class="text-(--crit-green)">&rarr;</span>
            File updated (<span class="text-(--crit-accent) ">8</span> edits detected)
          </div>
          <div>
            <span class="text-(--crit-accent) ">&rarr;</span>
            Round 2: diff ready - <span class="text-(--crit-green)">2 resolved</span>, 1 open
          </div>
        </div>
      </a>
      
<!-- Vim Keybindings -->
      <a
        href={~p"/features/vim-keybindings"}
        class="feature-card border border-(--crit-border) rounded-lg bg-(--crit-bg-secondary) p-6 flex flex-col gap-4 hover:border-(--crit-fg-dimmed) transition-[border-color] duration-150 no-underline text-inherit"
      >
        <div>
          <h3 class="text-base font-semibold tracking-tight mb-1">Vim Keybindings</h3>
          <p class="text-sm text-(--crit-fg-secondary) leading-relaxed">
            Navigate, comment, and finish reviews without touching the mouse.
          </p>
        </div>
        <div class="flex flex-col gap-2 text-xs select-none" aria-hidden="true">
          <div class="flex items-center gap-2">
            <kbd class="crit-kbd">j</kbd><kbd class="crit-kbd">k</kbd>
            <span class="text-(--crit-fg-muted)">navigate blocks</span>
          </div>
          <div class="flex items-center gap-2">
            <kbd class="crit-kbd">n</kbd><kbd class="crit-kbd">N</kbd>
            <span class="text-(--crit-fg-muted)">next / prev change</span>
          </div>
          <div class="flex items-center gap-2">
            <kbd class="crit-kbd">c</kbd>
            <span class="text-(--crit-fg-muted)">comment</span>
          </div>
          <div class="flex items-center gap-2">
            <kbd class="crit-kbd">e</kbd>
            <span class="text-(--crit-fg-muted)">edit</span>
            <kbd class="crit-kbd ml-2">d</kbd>
            <span class="text-(--crit-fg-muted)">delete</span>
          </div>
          <div class="flex items-center gap-2">
            <kbd class="crit-kbd">⇧F</kbd>
            <span class="text-(--crit-fg-muted)">finish review</span>
          </div>
          <div class="flex items-center gap-2">
            <kbd class="crit-kbd">?</kbd>
            <span class="text-(--crit-fg-muted)">all shortcuts</span>
          </div>
        </div>
      </a>
      
<!-- Share Reviews -->
      <a
        href={~p"/features/share-reviews"}
        class="feature-card border border-(--crit-border) rounded-lg bg-(--crit-bg-secondary) p-6 flex flex-col gap-4 hover:border-(--crit-fg-dimmed) transition-[border-color] duration-150 no-underline text-inherit"
      >
        <div>
          <h3 class="text-base font-semibold tracking-tight mb-1">Share Reviews</h3>
          <p class="text-sm text-(--crit-fg-secondary) leading-relaxed">
            Want a second opinion before handing off to the agent? One click generates a public link, no install needed. Comments are color-coded by author. Unpublish anytime.
          </p>
        </div>
        <div
          class="rounded-md border border-(--crit-border) bg-(--crit-bg-primary) overflow-hidden text-xs select-none"
          aria-hidden="true"
        >
          <div class="px-3 py-1.5 border-b border-(--crit-border) bg-(--crit-accent-subtle) flex items-center gap-2">
            <svg viewBox="0 0 16 16" class="size-3 fill-(--crit-accent)" aria-hidden="true">
              <path d="M7.775 3.275a.75.75 0 0 0 1.06 1.06l1.25-1.25a2 2 0 1 1 2.83 2.83l-2.5 2.5a2 2 0 0 1-2.83 0 .75.75 0 0 0-1.06 1.06 3.5 3.5 0 0 0 4.95 0l2.5-2.5a3.5 3.5 0 0 0-4.95-4.95l-1.25 1.25zm-.025 9.45a.75.75 0 0 0-1.06-1.06l-1.25 1.25a2 2 0 0 1-2.83-2.83l2.5-2.5a2 2 0 0 1 2.83 0 .75.75 0 1 0 1.06-1.06 3.5 3.5 0 0 0-4.95 0l-2.5 2.5a3.5 3.5 0 0 0 4.95 4.95l1.25-1.25z" />
            </svg>
            <span class="font-mono text-(--crit-accent)  font-semibold">Shared</span>
          </div>
          <div class="px-3 py-2 flex items-center gap-2 font-mono text-(--crit-fg-secondary)">
            <span class="truncate">crit.md/r/a8f3k2x</span>
            <span class="ml-auto text-(--crit-green) shrink-0">Copied &check;</span>
          </div>
        </div>
      </a>
      
<!-- Syntax Highlighting -->
      <a
        href={~p"/features/syntax-highlighting"}
        class="feature-card border border-(--crit-border) rounded-lg bg-(--crit-bg-secondary) p-6 flex flex-col gap-4 hover:border-(--crit-fg-dimmed) transition-[border-color] duration-150 no-underline text-inherit"
      >
        <div>
          <h3 class="text-base font-semibold tracking-tight mb-1">Syntax Highlighting</h3>
          <p class="text-sm text-(--crit-fg-secondary) leading-relaxed">
            190+ languages with highlight.js. Code blocks split per-line so you can comment inside them.
          </p>
        </div>
        <div
          class="rounded-md border border-(--crit-border) bg-(--crit-code-bg) p-3 text-xs font-mono leading-5 overflow-hidden select-none"
          aria-hidden="true"
        >
          <div>
            <span class="text-(--crit-red)">func</span>
            <span class="text-(--crit-accent) ">handler</span><span class="text-(--crit-fg-secondary)">(w, r) &#123;</span>
          </div>
          <div>
            <span class="text-(--crit-fg-secondary)">&nbsp; token := r.</span><span class="text-(--crit-accent) ">Header</span><span class="text-(--crit-fg-secondary)">.</span><span class="text-(--crit-accent) ">Get</span><span class="text-(--crit-fg-secondary)">(</span><span class="text-(--crit-green)">"Auth"</span><span class="text-(--crit-fg-secondary)">)</span>
          </div>
          <div>
            <span class="text-(--crit-fg-secondary)">&nbsp; </span><span class="text-(--crit-red)">if</span><span class="text-(--crit-fg-secondary)"> token == </span><span class="text-(--crit-green)">""</span><span class="text-(--crit-fg-secondary)"> &#123;</span>
          </div>
          <div>
            <span class="text-(--crit-fg-secondary)">&nbsp;&nbsp;&nbsp; w.</span><span class="text-(--crit-accent) ">WriteHeader</span><span class="text-(--crit-fg-secondary)">(</span><span class="text-(--crit-accent) ">401</span><span class="text-(--crit-fg-secondary)">)</span>
          </div>
          <div><span class="text-(--crit-fg-secondary)">&nbsp; &#125;</span></div>
          <div><span class="text-(--crit-fg-secondary)">&#125;</span></div>
        </div>
      </a>
      
<!-- Mermaid Diagrams -->
      <a
        href={~p"/features/mermaid-diagrams"}
        class="feature-card border border-(--crit-border) rounded-lg bg-(--crit-bg-secondary) p-6 flex flex-col gap-4 hover:border-(--crit-fg-dimmed) transition-[border-color] duration-150 no-underline text-inherit"
      >
        <div>
          <h3 class="text-base font-semibold tracking-tight mb-1">Mermaid Diagrams</h3>
          <p class="text-sm text-(--crit-fg-secondary) leading-relaxed">
            Fenced mermaid blocks render as interactive diagrams. Flowcharts, sequences, and more.
          </p>
        </div>
        <div
          class="rounded-md border border-(--crit-border) bg-(--crit-bg-primary) p-4 flex items-center justify-center select-none"
          aria-hidden="true"
        >
          <div class="flex items-center gap-2.5 text-xs font-mono">
            <div class="border border-(--crit-accent) rounded px-2.5 py-1 text-(--crit-accent) ">
              Auth
            </div>
            <svg
              class="w-4 h-3 text-(--crit-fg-dimmed)"
              viewBox="0 0 16 12"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path d="M0 6h12M10 2l4 4-4 4" />
            </svg>
            <div class="border border-(--crit-fg-muted) rounded px-2.5 py-1 text-(--crit-fg-secondary)">
              API
            </div>
            <svg
              class="w-4 h-3 text-(--crit-fg-dimmed)"
              viewBox="0 0 16 12"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path d="M0 6h12M10 2l4 4-4 4" />
            </svg>
            <div class="border border-(--crit-fg-muted) rounded px-2.5 py-1 text-(--crit-fg-secondary)">
              DB
            </div>
          </div>
        </div>
      </a>
      
<!-- Compact feature strip -->
      <div class="feature-card col-span-full flex flex-wrap justify-center gap-3 mt-1">
        <span class="feat-pill">
          <span class="text-(--crit-accent) ">&#9776;</span> Table of Contents
        </span>
        <span class="feat-pill">
          <span class="text-(--crit-accent) ">&#9680;</span> Dark &amp; Light Themes
        </span>
        <span class="feat-pill">
          <span class="text-(--crit-green)">&#8635;</span> Draft Autosave
        </span>
        <span class="feat-pill">
          <span class="text-(--crit-accent) ">&#9166;</span> Insert Suggestions
        </span>
        <span class="feat-pill">
          <span class="text-(--crit-green)">&#9673;</span> Single Binary
        </span>
        <span class="feat-pill">
          <span class="text-(--crit-accent) ">&#8644;</span> Concurrent Reviews
        </span>
      </div>
    </div>
  </section>

  <%!-- ===== Testimonials ===== --%>
  <section class="w-full mt-8 py-16 bg-(--crit-bg-secondary) max-sm:py-12">
    <div class="max-w-7xl mx-auto px-10 max-sm:px-5">
      <p class="font-mono text-xs tracking-[0.2em] uppercase text-(--crit-accent) mb-12">
        What engineers are saying
      </p>
      <div class="grid grid-cols-2 gap-12 max-sm:grid-cols-1 max-sm:gap-10" id="testimonials-grid">
        <div :for={testimonial <- @testimonials} class="feature-card relative">
          <span
            class="absolute -top-4 -left-3 text-[8rem] leading-none text-(--crit-accent) opacity-10 select-none pointer-events-none"
            aria-hidden="true"
          >
            &ldquo;
          </span>
          <p class="relative text-xl font-semibold leading-snug text-(--crit-fg-primary) mb-5">
            {testimonial.highlight}
          </p>
          <div class="relative space-y-3 mb-5">
            <p
              :for={paragraph <- testimonial.body}
              class="text-sm leading-relaxed text-(--crit-fg-muted)"
            >
              {paragraph}
            </p>
          </div>
          <p class="relative font-mono text-xs text-(--crit-fg-muted)">
            &mdash; <a
              href={testimonial.link}
              class="text-(--crit-fg-dimmed) hover:text-(--crit-accent) transition-colors"
              target="_blank"
              rel="noopener noreferrer"
            >{testimonial.author}</a>, {testimonial.role}
          </p>
        </div>
      </div>
      <p class="mt-10 text-xs text-(--crit-fg-dimmed)">
        Using crit? I'd love to hear from you.
        <a
          href="mailto:me@tomasztomczyk.com?subject=Crit%20testimonial"
          class="underline underline-offset-2 hover:text-(--crit-fg-muted) transition-colors"
        >
          me@tomasztomczyk.com
        </a>
      </p>
      <%!-- ===== Platform Stats ===== --%>
      <div
        class="mt-12 pt-10 border-t border-(--crit-border)"
        id="platform-stats"
      >
        <p class="font-mono text-xs text-(--crit-fg-dimmed) text-center mb-6">
          Shared to {CritWeb.Endpoint.host()}
        </p>
        <div class="flex items-center justify-center gap-12 max-sm:gap-6 max-sm:flex-col">
          <div class="stat-item text-center">
            <div
              class="text-4xl font-mono font-bold tracking-tight text-(--crit-accent) tabular-nums"
              data-count-to={@stats.reviews_created}
            >
              {format_stat(@stats.reviews_created)}
            </div>
            <div class="font-mono text-xs text-(--crit-fg-muted) mt-1.5">reviews</div>
          </div>
          <div class="stat-divider w-px h-8 bg-(--crit-border) max-sm:hidden"></div>
          <div class="stat-item text-center">
            <div
              class="text-4xl font-mono font-bold tracking-tight text-(--crit-accent) tabular-nums"
              data-count-to={@stats.comments_created}
            >
              {format_stat(@stats.comments_created)}
            </div>
            <div class="font-mono text-xs text-(--crit-fg-muted) mt-1.5">comments</div>
          </div>
          <div class="stat-divider w-px h-8 bg-(--crit-border) max-sm:hidden"></div>
          <div class="stat-item text-center">
            <div
              class="text-4xl font-mono font-bold tracking-tight text-(--crit-accent) tabular-nums"
              data-count-to={@stats.lines_reviewed}
            >
              {format_stat(@stats.lines_reviewed)}
            </div>
            <div class="font-mono text-xs text-(--crit-fg-muted) mt-1.5">lines</div>
          </div>
          <div class="stat-divider w-px h-8 bg-(--crit-border) max-sm:hidden"></div>
          <div class="stat-item text-center">
            <div
              class="text-4xl font-mono font-bold tracking-tight text-(--crit-accent) tabular-nums"
              data-count-bytes={@stats.bytes_stored}
            >
              {format_bytes(@stats.bytes_stored)}
            </div>
            <div class="font-mono text-xs text-(--crit-fg-muted) mt-1.5">data</div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <!-- ===== Self-Hosting ===== -->
  <section
    class="max-w-7xl mx-auto mt-16 mb-20 px-10 max-sm:px-5 w-full"
    id="self-hosting-card"
  >
    <a
      href="/self-hosting"
      class="feature-card block border border-(--crit-border) rounded-lg bg-(--crit-bg-secondary) p-6 hover:border-(--crit-accent) transition-colors"
    >
      <div class="flex items-center justify-between max-sm:flex-col max-sm:items-start max-sm:gap-4">
        <div>
          <h3 class="text-lg font-bold tracking-tight mb-1">Self-Host Crit Web</h3>
          <p class="text-sm text-(--crit-fg-secondary) leading-relaxed max-w-[520px]">
            Run your own instance with Docker. One command to start, automatic migrations, works with any Postgres database.
          </p>
        </div>
        <div
          class="rounded-md border border-(--crit-border) bg-(--crit-code-bg) p-3 text-xs font-mono leading-5 text-(--crit-fg-secondary) select-none shrink-0"
          aria-hidden="true"
        >
          <div><span class="text-(--crit-fg-muted)">$</span> docker compose up -d</div>
          <div class="text-(--crit-green)">✓ crit-web running on :4000</div>
        </div>
      </div>
    </a>
  </section>
</div>
