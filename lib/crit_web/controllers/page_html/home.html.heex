<Layouts.flash_group flash={@flash} />

<div class="min-h-screen bg-(--crit-bg-primary) text-(--crit-fg-primary) font-sans flex flex-col">
  <Layouts.site_header />

  <section class="max-w-[1100px] mx-auto mt-20 mb-8 px-10 w-full max-sm:px-5 max-sm:mt-12">
    <div class="flex items-start gap-14 max-lg:flex-col max-lg:gap-10">
      <div class="flex-1 min-w-0">
        <p class="font-mono text-xs tracking-widest uppercase text-(--crit-accent)  mb-3">
          Local-first · No login · Works with any agent
        </p>
        <h1 class="text-6xl font-bold leading-[1.05] tracking-tighter mb-6 max-sm:text-4xl">
          Don't let your agent<br />build the wrong thing<span class="text-(--crit-accent) ">.</span>
          <span class="crit-blink-cursor">
            ▍
          </span>
        </h1>
        <p class="text-lg max-sm:text-base leading-relaxed text-(--crit-fg-secondary) max-w-[480px] mb-8">
          Review plans before your agent writes code. Review code before you ship it.
          Leave inline comments in a browser-based UI, click Finish Review, and your agent
          picks up the feedback automatically. It iterates. You review the diff. Repeat.
        </p>
        <div class="flex gap-3 flex-wrap">
          <a
            href={~p"/getting-started"}
            class="inline-flex items-center px-6 py-2.5 bg-(--crit-accent) text-(--crit-bg-primary) rounded-md text-sm font-semibold no-underline hover:bg-(--crit-accent-hover) transition-colors"
          >
            Get started
          </a>
          <%= if @demo_token do %>
            <a
              href={~p"/r/#{@demo_token}"}
              class="inline-flex items-center px-6 py-2.5 border border-(--crit-border) text-(--crit-fg-secondary) rounded-md text-sm font-semibold no-underline hover:border-(--crit-fg-muted) hover:text-(--crit-fg-primary) transition-colors"
            >
              See demo
            </a>
          <% end %>
          <a
            href="https://github.com/tomasz-tomczyk/crit"
            class="inline-flex items-center gap-2 px-6 py-2.5 border border-(--crit-border) text-(--crit-fg-secondary) rounded-md text-sm font-semibold no-underline hover:border-(--crit-fg-muted) hover:text-(--crit-fg-primary) transition-colors"
          >
            <svg viewBox="0 0 16 16" class="size-3.5 fill-current opacity-70" aria-hidden="true">
              <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z" />
            </svg>
            Star on GitHub
          </a>
        </div>
      </div>

      <div class="w-[440px] shrink-0 max-lg:w-full">
        <div class="border border-(--crit-border) rounded-lg overflow-hidden bg-(--crit-bg-secondary)">
          <div class="flex items-center gap-2 px-4 py-2.5 border-b border-(--crit-border) bg-(--crit-bg-tertiary)">
            <span class="font-mono text-[11px] font-semibold text-(--crit-fg-secondary)">
              Crit
            </span>
            <span class="text-(--crit-fg-dimmed) text-[10px]">/</span>
            <span class="font-mono text-[11px] text-(--crit-fg-muted) bg-(--crit-bg-secondary) px-2 py-0.5 rounded">
              plan.md
            </span>
            <div class="ml-auto">
              <span class="font-mono text-[11px] text-(--crit-fg-muted)">
                <strong class="text-(--crit-accent) ">2</strong> comments
              </span>
            </div>
          </div>

          <div class="font-mono text-[12px] leading-6 select-none">
            <div class="flex border-l-[3px] border-transparent">
              <div class="w-[42px] shrink-0 text-right pr-3 py-0.5 text-(--crit-fg-dimmed)">
                1
              </div>
              <div class="flex-1 px-3 py-0.5 font-sans font-bold text-[14px] text-(--crit-fg-primary)">
                # Implement auth system
              </div>
            </div>
            <div class="flex border-l-[3px] border-transparent">
              <div class="w-[42px] shrink-0 text-right pr-3 py-0.5 text-(--crit-fg-dimmed)">
                2
              </div>
              <div class="flex-1 px-3 py-0.5">&nbsp;</div>
            </div>
            <div class="flex border-l-[3px] border-transparent">
              <div class="w-[42px] shrink-0 text-right pr-3 py-0.5 text-(--crit-fg-dimmed)">
                3
              </div>
              <div class="flex-1 px-3 py-0.5 font-sans font-semibold text-[13px] text-(--crit-fg-primary)">
                ## Backend
              </div>
            </div>
            <div class="flex border-l-[3px] border-(--crit-accent) bg-(--crit-accent-subtle)">
              <div class="w-[42px] shrink-0 text-right pr-3 py-0.5 text-(--crit-accent) ">
                4
              </div>
              <div class="flex-1 px-3 py-0.5 font-sans text-[12px] text-(--crit-fg-secondary)">
                Use JWT tokens for sessions.
              </div>
            </div>
            <div class="mx-3 mb-1 mt-0.5 border border-(--crit-border-comment) rounded text-[11px] overflow-hidden bg-(--crit-comment-bg)">
              <div class="px-3 py-1.5 border-b border-(--crit-border) flex items-center gap-2 bg-(--crit-accent-subtle)">
                <svg
                  viewBox="0 0 16 16"
                  class="size-3 fill-(--crit-accent) shrink-0"
                  aria-hidden="true"
                >
                  <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
                </svg>
                <span class="font-sans font-semibold text-(--crit-accent) ">You</span>
                <span class="text-(--crit-fg-dimmed)">·</span>
                <span class="font-sans text-(--crit-fg-muted)">Line 4</span>
                <span class="text-(--crit-fg-dimmed)">·</span>
                <span class="font-sans text-(--crit-fg-muted)">14:22</span>
                <span class="ml-auto font-sans text-(--crit-fg-muted)">Edit · Delete</span>
              </div>
              <div class="px-3 py-2 font-sans text-(--crit-fg-secondary) leading-relaxed">
                Consider OAuth2 instead. Simpler for users, no token refresh logic needed.
              </div>
            </div>
            <div class="flex border-l-[3px] border-transparent">
              <div class="w-[42px] shrink-0 text-right pr-3 py-0.5 text-(--crit-fg-dimmed)">
                5
              </div>
              <div class="flex-1 px-3 py-0.5 font-sans text-[12px] text-(--crit-fg-secondary)">
                Rate limit all endpoints.
              </div>
            </div>
            <div class="flex border-l-[3px] border-(--crit-accent) bg-(--crit-accent-subtle)">
              <div class="w-[42px] shrink-0 text-right pr-3 py-0.5 text-(--crit-accent) ">
                6
              </div>
              <div class="flex-1 px-3 py-0.5 font-sans text-[12px] text-(--crit-fg-secondary)">
                Store passwords with bcrypt.
              </div>
            </div>
            <div class="mx-3 mb-3 mt-0.5 border border-(--crit-border-comment) rounded text-[11px] overflow-hidden bg-(--crit-comment-bg)">
              <div class="px-3 py-1.5 border-b border-(--crit-border) flex items-center gap-2 bg-(--crit-accent-subtle)">
                <svg
                  viewBox="0 0 16 16"
                  class="size-3 fill-(--crit-accent) shrink-0"
                  aria-hidden="true"
                >
                  <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
                </svg>
                <span class="font-sans font-semibold text-(--crit-accent) ">You</span>
                <span class="text-(--crit-fg-dimmed)">·</span>
                <span class="font-sans text-(--crit-fg-muted)">Line 6</span>
                <span class="text-(--crit-fg-dimmed)">·</span>
                <span class="font-sans text-(--crit-fg-muted)">14:23</span>
                <span class="ml-auto font-sans text-(--crit-fg-muted)">Edit · Delete</span>
              </div>
              <div class="px-3 py-2 font-sans text-(--crit-fg-secondary) leading-relaxed">
                bcrypt is fine but argon2id is the current recommendation.
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  
<!-- ===== How it works ===== -->
  <section class="max-w-[1100px] mx-auto mt-16 px-10 max-sm:px-5 w-full" id="how-it-works">
    <p class="font-mono text-xs tracking-widest uppercase text-(--crit-accent) mb-3">
      How it works
    </p>
    <h2 class="text-3xl font-bold tracking-tight mb-10 max-sm:text-2xl max-sm:mb-8">
      You direct. Your agent executes<span class="text-(--crit-accent)">.</span>
    </h2>

    <div class="grid grid-cols-4 gap-4 max-lg:grid-cols-2 max-sm:grid-cols-1">
      <div class="border border-(--crit-border) rounded-lg bg-(--crit-bg-secondary) p-5">
        <div class="font-mono text-xs text-(--crit-accent) mb-2">01</div>
        <h3 class="text-sm font-semibold mb-2">Open for review</h3>
        <pre class="rounded-md border border-(--crit-border) bg-(--crit-code-bg) p-2.5 text-[10px] font-mono leading-5 text-(--crit-fg-secondary) select-none m-0 overflow-hidden"><span class="text-(--crit-fg-muted)">$</span> crit plan.md
<span class="text-(--crit-fg-muted)">$</span> crit</pre>
        <p class="text-[10px] text-(--crit-fg-muted) mt-1.5 leading-snug">
          Any file, or no args to auto-detect changes.
        </p>
      </div>

      <div class="border border-(--crit-border) rounded-lg bg-(--crit-bg-secondary) p-5">
        <div class="font-mono text-xs text-(--crit-accent) mb-2">02</div>
        <h3 class="text-sm font-semibold mb-2">Finish review</h3>
        <div class="rounded-md border border-(--crit-border) bg-(--crit-code-bg) p-2.5 text-[10px] font-mono leading-5 text-(--crit-fg-secondary) select-none">
          <div>
            <span class="text-(--crit-green)">&rarr;</span>
            Agent notified <span class="text-(--crit-green)">&check;</span>
          </div>
          <div class="text-(--crit-fg-muted)">&nbsp; Waiting for updates&hellip;</div>
        </div>
      </div>

      <div class="border border-(--crit-border) rounded-lg bg-(--crit-bg-secondary) p-5">
        <div class="font-mono text-xs text-(--crit-accent) mb-2">03</div>
        <h3 class="text-sm font-semibold mb-2">Agent edits &amp; signals done</h3>
        <div class="rounded-md border border-(--crit-border) bg-(--crit-code-bg) p-2.5 text-[10px] font-mono leading-5 text-(--crit-fg-secondary) select-none">
          <div class="text-(--crit-fg-muted)">&nbsp; Agent addresses feedback&hellip;</div>
          <div><span class="text-(--crit-fg-muted)">$</span> crit go 3247</div>
        </div>
      </div>

      <div class="border border-(--crit-border) rounded-lg bg-(--crit-bg-secondary) p-5">
        <div class="font-mono text-xs text-(--crit-accent) mb-2">04</div>
        <h3 class="text-sm font-semibold mb-2">Diff &amp; repeat</h3>
        <div class="rounded-md border border-(--crit-border) bg-(--crit-code-bg) p-2.5 text-[10px] font-mono leading-5 text-(--crit-fg-secondary) select-none">
          <div><span class="text-(--crit-accent)">&rarr;</span> Round 2: diff ready</div>
          <div><span class="text-(--crit-green)">&rarr;</span> 2 resolved, 1 open</div>
          <div class="text-(--crit-fg-muted)">&nbsp; Review again&hellip;</div>
        </div>
      </div>
    </div>

    <p class="text-sm text-(--crit-fg-muted) mt-5 text-center">
      Works with Claude Code, Cursor, GitHub Copilot, Aider, Cline, Windsurf, or any agent that reads files.
      <a href={~p"/integrations"} class="text-(--crit-accent) no-underline hover:underline">
        Set up your agent &rarr;
      </a>
    </p>
  </section>
  
<!-- ===== Install ===== -->
  <section class="max-w-[1100px] mx-auto mt-10 px-10 max-sm:px-5 w-full" id="install">
    <div class="flex gap-14 items-start max-lg:flex-col max-lg:gap-6">
      <div class="w-[280px] shrink-0 max-lg:w-full">
        <h2 class="text-2xl font-bold tracking-tight mb-3">Install</h2>
        <p class="text-sm text-(--crit-fg-secondary) leading-relaxed">
          Single binary, zero dependencies. Pick your package manager and start reviewing in seconds.
        </p>
      </div>
      <div class="flex-1 min-w-0 max-lg:w-full">
        <CritWeb.PageHTML.install_widget />
      </div>
    </div>
  </section>
  
<!-- ===== Demo Video ===== -->
  <section class="max-w-[1100px] mx-auto mt-10 px-10 max-sm:px-5 w-full">
    <p class="text-sm text-(--crit-fg-muted) mb-3">
      2-minute walkthrough of plan review: leaving inline comments and handing off to an agent. Branch review uses the same UI with git diffs.
    </p>
    <div
      class="relative w-full rounded-lg overflow-hidden border border-(--crit-border) cursor-pointer group"
      style="aspect-ratio: 16/9;"
      id="yt-facade"
      aria-label="Play Crit demo video"
      role="button"
      tabindex="0"
    >
      <img
        src="https://i.ytimg.com/vi/w_Dswm2Ft-o/maxresdefault.jpg"
        alt="Crit demo video thumbnail"
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 flex items-center justify-center bg-black/20 group-hover:bg-black/40 transition-colors">
        <svg viewBox="0 0 68 48" class="w-[68px] h-[48px] drop-shadow-lg" aria-hidden="true">
          <path
            d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55C3.97 2.33 2.27 4.81 1.48 7.74.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z"
            fill="#f00"
          />
          <path d="M45 24 27 14v20" fill="#fff" />
        </svg>
      </div>
    </div>
  </section>
  
<!-- ===== Features ===== -->
  <section
    class="max-w-[1100px] mx-auto mt-14 mb-16 px-10 max-sm:px-5 max-sm:mt-10 w-full"
    id="features"
  >
    <p class="font-mono text-xs tracking-widest uppercase text-(--crit-accent) mb-3">
      Features
    </p>
    <h2 class="text-3xl font-bold tracking-tight mb-10 max-sm:text-2xl max-sm:mb-8">
      Built for the review-then-build loop<span class="text-(--crit-accent) ">.</span>
    </h2>

    <div class="grid grid-cols-3 gap-3 max-lg:grid-cols-2 max-sm:grid-cols-1" id="features-grid">
      
<!-- Inline Comments -->
      <a
        href={~p"/features/inline-comments"}
        class="feature-card col-span-2 max-lg:col-span-1 border border-(--crit-border) rounded-lg bg-(--crit-bg-secondary) p-5 flex flex-col gap-4 hover:border-(--crit-fg-dimmed) transition-[border-color] duration-150 no-underline text-inherit"
      >
        <div>
          <h3 class="text-base font-semibold tracking-tight mb-1">Inline Comments</h3>
          <p class="text-sm text-(--crit-fg-secondary) leading-relaxed">
            Click and drag line numbers to select ranges. Leave PR-style inline comments on any block.
          </p>
        </div>
        <div
          class="rounded-md border border-(--crit-border) bg-(--crit-bg-primary) overflow-hidden text-[10px] font-mono leading-5 select-none"
          aria-hidden="true"
        >
          <div class="flex">
            <span class="w-7 text-right pr-2 py-px text-(--crit-fg-dimmed) shrink-0">3</span>
            <span class="flex-1 px-2 py-px text-(--crit-fg-primary) font-sans font-semibold text-[11px]">
              ## Backend
            </span>
          </div>
          <div class="flex border-l-2 border-(--crit-accent) bg-(--crit-accent-subtle)">
            <span class="w-7 text-right pr-2 py-px text-(--crit-accent)  shrink-0">4</span>
            <span class="flex-1 px-2 py-px text-(--crit-fg-secondary) font-sans">
              Use JWT tokens for sessions.
            </span>
          </div>
          <div class="ml-7 mr-2 my-1 border border-(--crit-border-comment) rounded text-[9px] bg-(--crit-comment-bg) overflow-hidden">
            <div class="px-2 py-1 bg-(--crit-accent-subtle) border-b border-(--crit-border) font-sans flex items-center gap-1.5">
              <span class="text-(--crit-accent)  font-semibold">You</span>
              <span class="text-(--crit-fg-dimmed)">&middot;</span>
              <span class="text-(--crit-fg-muted)">Line 4</span>
            </div>
            <div class="px-2 py-1.5 text-(--crit-fg-secondary) font-sans">
              Consider OAuth2 instead - simpler for users.
            </div>
          </div>
          <div class="flex">
            <span class="w-7 text-right pr-2 py-px text-(--crit-fg-dimmed) shrink-0">5</span>
            <span class="flex-1 px-2 py-px text-(--crit-fg-secondary) font-sans">
              Rate limit all endpoints.
            </span>
          </div>
        </div>
      </a>
      
<!-- Diff Viewer -->
      <a
        href={~p"/features/split-unified-diff"}
        class="feature-card border border-(--crit-border) rounded-lg bg-(--crit-bg-secondary) p-5 flex flex-col gap-4 hover:border-(--crit-fg-dimmed) transition-[border-color] duration-150 no-underline text-inherit"
      >
        <div>
          <h3 class="text-base font-semibold tracking-tight mb-1">Git Diffs & Round Diffs</h3>
          <p class="text-sm text-(--crit-fg-secondary) leading-relaxed">
            Review code as git diffs. See what changed between rounds. Split or unified views.
          </p>
        </div>
        <div
          class="rounded-md border border-(--crit-border) overflow-hidden text-[9px] font-mono leading-4 select-none"
          aria-hidden="true"
        >
          <div class="grid grid-cols-2">
            <div class="px-2 py-1 bg-(--crit-bg-tertiary) text-(--crit-fg-muted) border-b border-r border-(--crit-border) font-sans font-semibold text-[8px]">
              Previous
            </div>
            <div class="px-2 py-1 bg-(--crit-bg-tertiary) text-(--crit-fg-muted) border-b border-(--crit-border) font-sans font-semibold text-[8px]">
              Current
            </div>
          </div>
          <div class="grid grid-cols-2">
            <div class="px-2 py-0.5 bg-(--crit-bg-primary) text-(--crit-fg-secondary) border-r border-(--crit-border)">
              Use JWT tokens
            </div>
            <div class="px-2 py-0.5 bg-(--crit-bg-primary) text-(--crit-fg-secondary)">
              Use JWT tokens
            </div>
          </div>
          <div class="grid grid-cols-2">
            <div class="px-2 py-0.5 diff-removed-bg text-(--crit-red) line-through opacity-70 border-r border-(--crit-border)">
              bcrypt hashing
            </div>
            <div class="px-2 py-0.5 diff-added-bg text-(--crit-green)">argon2id hashing</div>
          </div>
          <div class="grid grid-cols-2">
            <div class="px-2 py-0.5 bg-(--crit-bg-primary) text-(--crit-fg-secondary) border-r border-(--crit-border)">
              Rate limit all
            </div>
            <div class="px-2 py-0.5 bg-(--crit-bg-primary) text-(--crit-fg-secondary)">
              Rate limit all
            </div>
          </div>
          <div class="grid grid-cols-2">
            <div class="px-2 py-0.5 bg-(--crit-bg-primary) border-r border-(--crit-border)">
              &nbsp;
            </div>
            <div class="px-2 py-0.5 diff-added-bg text-(--crit-green)">
              + Add CORS headers
            </div>
          </div>
        </div>
      </a>
      
<!-- AI Review Loop -->
      <a
        href={~p"/features/ai-review-loop"}
        class="feature-card col-span-2 max-sm:col-span-1 border border-(--crit-border) rounded-lg bg-(--crit-bg-secondary) p-5 flex flex-col gap-4 hover:border-(--crit-fg-dimmed) transition-[border-color] duration-150 no-underline text-inherit"
      >
        <div>
          <h3 class="text-base font-semibold tracking-tight mb-1">AI Review Loop</h3>
          <p class="text-sm text-(--crit-fg-secondary) leading-relaxed">
            Leave comments, click finish, and your agent picks up the feedback automatically. It edits the file. Crit reloads with a diff of what changed. Previous comments stay visible so nothing gets skipped.
          </p>
        </div>
        <div
          class="rounded-md border border-(--crit-border) bg-(--crit-code-bg) p-3 text-[10px] font-mono leading-5 text-(--crit-fg-secondary) select-none"
          aria-hidden="true"
        >
          <div><span class="text-(--crit-fg-muted)">$</span> crit</div>
          <div class="text-(--crit-fg-muted)">&nbsp; Listening on http://localhost:3247</div>
          <div>
            <span class="text-(--crit-accent) ">&rarr;</span>
            Round 1: <span class="text-(--crit-accent) ">3</span>
            comments added
          </div>
          <div>
            <span class="text-(--crit-green)">&rarr;</span>
            Finish review - agent notified <span class="text-(--crit-green)">&check;</span>
          </div>
          <div>
            <span class="text-(--crit-fg-muted)">&rarr;</span> Agent working&hellip;
          </div>
          <div>
            <span class="text-(--crit-green)">&rarr;</span>
            File updated (<span class="text-(--crit-accent) ">8</span> edits detected)
          </div>
          <div>
            <span class="text-(--crit-accent) ">&rarr;</span>
            Round 2: diff ready - <span class="text-(--crit-green)">2 resolved</span>, 1 open
          </div>
        </div>
      </a>
      
<!-- Vim Keybindings -->
      <a
        href={~p"/features/vim-keybindings"}
        class="feature-card border border-(--crit-border) rounded-lg bg-(--crit-bg-secondary) p-5 flex flex-col gap-4 hover:border-(--crit-fg-dimmed) transition-[border-color] duration-150 no-underline text-inherit"
      >
        <div>
          <h3 class="text-base font-semibold tracking-tight mb-1">Vim Keybindings</h3>
          <p class="text-sm text-(--crit-fg-secondary) leading-relaxed">
            Navigate, comment, and finish reviews without touching the mouse.
          </p>
        </div>
        <div class="flex flex-col gap-2 text-[11px] select-none" aria-hidden="true">
          <div class="flex items-center gap-2">
            <kbd class="crit-kbd">j</kbd><kbd class="crit-kbd">k</kbd>
            <span class="text-(--crit-fg-muted)">navigate blocks</span>
          </div>
          <div class="flex items-center gap-2">
            <kbd class="crit-kbd">n</kbd><kbd class="crit-kbd">N</kbd>
            <span class="text-(--crit-fg-muted)">next / prev change</span>
          </div>
          <div class="flex items-center gap-2">
            <kbd class="crit-kbd">c</kbd>
            <span class="text-(--crit-fg-muted)">comment</span>
          </div>
          <div class="flex items-center gap-2">
            <kbd class="crit-kbd">e</kbd>
            <span class="text-(--crit-fg-muted)">edit</span>
            <kbd class="crit-kbd ml-2">d</kbd>
            <span class="text-(--crit-fg-muted)">delete</span>
          </div>
          <div class="flex items-center gap-2">
            <kbd class="crit-kbd">⇧F</kbd>
            <span class="text-(--crit-fg-muted)">finish review</span>
          </div>
          <div class="flex items-center gap-2">
            <kbd class="crit-kbd">?</kbd>
            <span class="text-(--crit-fg-muted)">all shortcuts</span>
          </div>
        </div>
      </a>
      
<!-- Share Reviews -->
      <a
        href={~p"/features/share-reviews"}
        class="feature-card border border-(--crit-border) rounded-lg bg-(--crit-bg-secondary) p-5 flex flex-col gap-4 hover:border-(--crit-fg-dimmed) transition-[border-color] duration-150 no-underline text-inherit"
      >
        <div>
          <h3 class="text-base font-semibold tracking-tight mb-1">Share Reviews</h3>
          <p class="text-sm text-(--crit-fg-secondary) leading-relaxed">
            Want a second opinion before handing off to the agent? One click generates a public link, no install needed. Comments are color-coded by author. Unpublish anytime.
          </p>
        </div>
        <div
          class="rounded-md border border-(--crit-border) bg-(--crit-bg-primary) overflow-hidden text-[10px] select-none"
          aria-hidden="true"
        >
          <div class="px-3 py-1.5 border-b border-(--crit-border) bg-(--crit-accent-subtle) flex items-center gap-2">
            <svg viewBox="0 0 16 16" class="size-3 fill-(--crit-accent)" aria-hidden="true">
              <path d="M7.775 3.275a.75.75 0 0 0 1.06 1.06l1.25-1.25a2 2 0 1 1 2.83 2.83l-2.5 2.5a2 2 0 0 1-2.83 0 .75.75 0 0 0-1.06 1.06 3.5 3.5 0 0 0 4.95 0l2.5-2.5a3.5 3.5 0 0 0-4.95-4.95l-1.25 1.25zm-.025 9.45a.75.75 0 0 0-1.06-1.06l-1.25 1.25a2 2 0 0 1-2.83-2.83l2.5-2.5a2 2 0 0 1 2.83 0 .75.75 0 1 0 1.06-1.06 3.5 3.5 0 0 0-4.95 0l-2.5 2.5a3.5 3.5 0 0 0 4.95 4.95l1.25-1.25z" />
            </svg>
            <span class="font-mono text-(--crit-accent)  font-semibold">Shared</span>
          </div>
          <div class="px-3 py-2 flex items-center gap-2 font-mono text-(--crit-fg-secondary)">
            <span class="truncate">crit.live/r/a8f3k2x</span>
            <span class="ml-auto text-(--crit-green) shrink-0">Copied &check;</span>
          </div>
        </div>
      </a>
      
<!-- Syntax Highlighting -->
      <a
        href={~p"/features/syntax-highlighting"}
        class="feature-card border border-(--crit-border) rounded-lg bg-(--crit-bg-secondary) p-5 flex flex-col gap-4 hover:border-(--crit-fg-dimmed) transition-[border-color] duration-150 no-underline text-inherit"
      >
        <div>
          <h3 class="text-base font-semibold tracking-tight mb-1">Syntax Highlighting</h3>
          <p class="text-sm text-(--crit-fg-secondary) leading-relaxed">
            13+ languages with highlight.js. Code blocks split per-line so you can comment inside them.
          </p>
        </div>
        <div
          class="rounded-md border border-(--crit-border) bg-(--crit-code-bg) p-3 text-[10px] font-mono leading-5 overflow-hidden select-none"
          aria-hidden="true"
        >
          <div>
            <span class="text-(--crit-red)">func</span>
            <span class="text-(--crit-accent) ">handler</span><span class="text-(--crit-fg-secondary)">(w, r) &#123;</span>
          </div>
          <div>
            <span class="text-(--crit-fg-secondary)">&nbsp; token := r.</span><span class="text-(--crit-accent) ">Header</span><span class="text-(--crit-fg-secondary)">.</span><span class="text-(--crit-accent) ">Get</span><span class="text-(--crit-fg-secondary)">(</span><span class="text-(--crit-green)">"Auth"</span><span class="text-(--crit-fg-secondary)">)</span>
          </div>
          <div>
            <span class="text-(--crit-fg-secondary)">&nbsp; </span><span class="text-(--crit-red)">if</span><span class="text-(--crit-fg-secondary)"> token == </span><span class="text-(--crit-green)">""</span><span class="text-(--crit-fg-secondary)"> &#123;</span>
          </div>
          <div>
            <span class="text-(--crit-fg-secondary)">&nbsp;&nbsp;&nbsp; w.</span><span class="text-(--crit-accent) ">WriteHeader</span><span class="text-(--crit-fg-secondary)">(</span><span class="text-(--crit-accent) ">401</span><span class="text-(--crit-fg-secondary)">)</span>
          </div>
          <div><span class="text-(--crit-fg-secondary)">&nbsp; &#125;</span></div>
          <div><span class="text-(--crit-fg-secondary)">&#125;</span></div>
        </div>
      </a>
      
<!-- Mermaid Diagrams -->
      <a
        href={~p"/features/mermaid-diagrams"}
        class="feature-card border border-(--crit-border) rounded-lg bg-(--crit-bg-secondary) p-5 flex flex-col gap-4 hover:border-(--crit-fg-dimmed) transition-[border-color] duration-150 no-underline text-inherit"
      >
        <div>
          <h3 class="text-base font-semibold tracking-tight mb-1">Mermaid Diagrams</h3>
          <p class="text-sm text-(--crit-fg-secondary) leading-relaxed">
            Fenced mermaid blocks render as interactive diagrams. Flowcharts, sequences, and more.
          </p>
        </div>
        <div
          class="rounded-md border border-(--crit-border) bg-(--crit-bg-primary) p-4 flex items-center justify-center select-none"
          aria-hidden="true"
        >
          <div class="flex items-center gap-2.5 text-[9px] font-mono">
            <div class="border border-(--crit-accent) rounded px-2.5 py-1 text-(--crit-accent) ">
              Auth
            </div>
            <svg
              class="w-4 h-3 text-(--crit-fg-dimmed)"
              viewBox="0 0 16 12"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path d="M0 6h12M10 2l4 4-4 4" />
            </svg>
            <div class="border border-(--crit-fg-muted) rounded px-2.5 py-1 text-(--crit-fg-secondary)">
              API
            </div>
            <svg
              class="w-4 h-3 text-(--crit-fg-dimmed)"
              viewBox="0 0 16 12"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path d="M0 6h12M10 2l4 4-4 4" />
            </svg>
            <div class="border border-(--crit-fg-muted) rounded px-2.5 py-1 text-(--crit-fg-secondary)">
              DB
            </div>
          </div>
        </div>
      </a>
      
<!-- Compact feature strip -->
      <div class="feature-card col-span-full flex flex-wrap justify-center gap-3 mt-1">
        <span class="feat-pill">
          <span class="text-(--crit-accent) ">&#9776;</span> Table of Contents
        </span>
        <span class="feat-pill">
          <span class="text-(--crit-accent) ">&#9680;</span> Dark &amp; Light Themes
        </span>
        <span class="feat-pill">
          <span class="text-(--crit-green)">&#8635;</span> Draft Autosave
        </span>
        <span class="feat-pill">
          <span class="text-(--crit-accent) ">&#9166;</span> Insert Suggestions
        </span>
        <span class="feat-pill">
          <span class="text-(--crit-green)">&#9673;</span> Single Binary
        </span>
        <span class="feat-pill">
          <span class="text-(--crit-accent) ">&#8644;</span> Concurrent Reviews
        </span>
      </div>
    </div>
  </section>
  
<!-- ===== Self-Hosting ===== -->
  <section
    class="max-w-[1100px] mx-auto mt-2 mb-16 px-10 max-sm:px-5 w-full"
    id="self-hosting-card"
  >
    <a
      href="/self-hosting"
      class="feature-card block border border-(--crit-border) rounded-lg bg-(--crit-bg-secondary) p-6 hover:border-(--crit-accent) transition-colors"
    >
      <div class="flex items-center justify-between max-sm:flex-col max-sm:items-start max-sm:gap-4">
        <div>
          <h3 class="text-lg font-semibold tracking-tight mb-1">Self-Host Crit Web</h3>
          <p class="text-sm text-(--crit-fg-secondary) leading-relaxed max-w-[520px]">
            Run your own instance with Docker. One command to start, automatic migrations, works with any Postgres database.
          </p>
        </div>
        <div
          class="rounded-md border border-(--crit-border) bg-(--crit-code-bg) p-3 text-[11px] font-mono leading-5 text-(--crit-fg-secondary) select-none shrink-0"
          aria-hidden="true"
        >
          <div><span class="text-(--crit-fg-muted)">$</span> docker compose up -d</div>
          <div class="text-(--crit-green)">✓ crit-web running on :4000</div>
        </div>
      </div>
    </a>
  </section>
</div>
