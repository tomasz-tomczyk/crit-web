<Layouts.flash_group flash={@flash} />

<div class="min-h-screen bg-(--crit-bg-page) text-(--crit-fg-primary) font-sans flex flex-col">
  <Layouts.site_header current_scope={@current_scope} />

  <section class="max-w-7xl mx-auto pt-24 pb-16 px-10 w-full max-sm:px-4 max-sm:pt-14 max-sm:pb-10">
    <div class="max-w-3xl mb-14 max-sm:mb-10">
      <p class="font-mono text-xs tracking-widest uppercase text-(--crit-brand) mb-5">
        Local-first · No login · Works with any agent
      </p>
      <h1 class="text-7xl font-extrabold leading-none tracking-tight mb-7 max-lg:text-6xl max-sm:text-5xl">
        Your feedback loop with the
        <span class="whitespace-nowrap">
          agent<span class="text-(--crit-brand)">.</span>
          <span class="crit-blink-cursor">
            ▍
          </span>
        </span>
      </h1>
      <p class="text-xl max-sm:text-base leading-relaxed text-(--crit-fg-secondary) max-w-2xl mb-10">
        Review plans before your agent writes code. Review code before you ship it.
        Leave comments, click Finish Review, and your agent acts on the feedback automatically. Repeat as needed. Local by default.
      </p>
      <div class="flex gap-3 flex-wrap max-sm:grid max-sm:grid-cols-2">
        <a
          href={~p"/getting-started"}
          class="inline-flex items-center justify-center px-7 py-3 bg-(--crit-brand-cta) text-(--crit-fg-on-brand) rounded-lg text-sm font-bold no-underline hover:bg-(--crit-brand-cta-hover) transition-all"
        >
          Get started
        </a>
        <%= if @demo_token do %>
          <a
            href={~p"/r/#{@demo_token}"}
            class="inline-flex items-center justify-center px-7 py-3 border border-(--crit-border) text-(--crit-fg-secondary) rounded-lg text-sm font-semibold no-underline hover:border-(--crit-fg-muted) hover:text-(--crit-fg-primary) transition-all"
          >
            See demo
          </a>
        <% end %>
        <a
          href="https://github.com/tomasz-tomczyk/crit"
          class="group/star inline-flex items-center justify-center gap-2 px-7 py-3 border border-(--crit-border) text-(--crit-fg-secondary) rounded-lg text-sm font-semibold no-underline hover:bg-(--crit-yellow-subtle) hover:border-(--crit-yellow) hover:text-(--crit-yellow) transition-all max-sm:col-span-2"
        >
          <svg
            viewBox="0 0 16 16"
            class="size-4 fill-current opacity-60 group-hover/star:opacity-100 group-hover/star:text-(--crit-yellow) group-hover/star:scale-110 transition-all duration-200"
            aria-hidden="true"
          >
            <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z" />
          </svg>
          Star on GitHub
        </a>
      </div>
    </div>

    <div
      class="relative w-full rounded-xl overflow-hidden border border-(--crit-border) cursor-pointer group"
      style="aspect-ratio: 16/9;"
      id="yt-facade"
      aria-label="Play Crit demo video"
      role="button"
      tabindex="0"
    >
      <img
        src="/images/video-thumbnail.png"
        alt="Crit demo video thumbnail"
        class="absolute inset-0 w-full h-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 flex items-center justify-center bg-black/20 group-hover:bg-black/40 transition-colors">
        <svg viewBox="0 0 68 48" class="w-[68px] h-[48px] drop-shadow-lg" aria-hidden="true">
          <path
            d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55C3.97 2.33 2.27 4.81 1.48 7.74.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z"
            fill="#f00"
          />
          <path d="M45 24 27 14v20" fill="#fff" />
        </svg>
      </div>
    </div>
  </section>
  
<!-- ===== Install ===== -->
  <section class="max-w-7xl mx-auto mt-16 px-10 max-sm:px-4 w-full" id="install">
    <div class="flex gap-14 items-start max-lg:flex-col max-lg:gap-6">
      <div class="w-[300px] shrink-0 max-lg:w-full">
        <h2 class="text-2xl font-extrabold tracking-tight mb-3">Install</h2>
        <p class="text-sm text-(--crit-fg-secondary) leading-relaxed">
          Single binary. Reviews stay on your machine - sharing is opt-in.
        </p>
      </div>
      <div class="flex-1 min-w-0 max-lg:w-full">
        <CritWeb.PageHTML.install_widget />
      </div>
    </div>
  </section>
  
<!-- ===== Agent Setup ===== -->
  <section class="max-w-7xl mx-auto mt-8 px-10 max-sm:px-4 w-full" id="agent-setup">
    <div class="flex gap-14 items-start max-lg:flex-col max-lg:gap-6">
      <div class="w-[300px] shrink-0 max-lg:w-full">
        <h2 class="text-2xl font-extrabold tracking-tight mb-3">Connect your agent</h2>
        <p class="text-sm text-(--crit-fg-secondary) leading-relaxed">
          Add skills to teach your agent how to use Crit.
        </p>
      </div>
      <div class="flex-1 min-w-0 max-lg:w-full">
        <CritWeb.PageHTML.agent_setup_widget />
      </div>
    </div>
  </section>

  <%!-- ===== Primary feature: AI review loop ===== --%>
  <section
    class="max-w-7xl mx-auto mt-32 px-10 max-sm:px-4 max-sm:mt-16 w-full"
    id="features"
  >
    <div class="max-w-[640px] mb-8 max-sm:mb-6">
      <p class="font-mono text-xs tracking-widest uppercase text-(--crit-brand) mb-3">
        The core loop
      </p>
      <h3 class="text-3xl font-extrabold tracking-tight mb-3 max-sm:text-2xl text-balance">
        Comment in. Agent updates. Diff out.
      </h3>
      <p class="text-lg text-(--crit-fg-secondary) leading-relaxed max-sm:text-base">
        Drag across a range of lines, leave comments, hit <strong class="text-(--crit-fg-primary) font-semibold">Finish Review</strong>.
        Your agent picks up the feedback, edits the file, and Crit reloads with a diff so
        you can keep iterating without losing context. Previous comments stay visible - resolve only when you're satisfied.
      </p>
    </div>
    <figure class="not-prose">
      <img
        src="/images/screenshots/ai-loop-dark.png"
        alt="Crit reviewing a plan: inline comments, agent replies, and round-2 diff"
        class="logo-dark w-full rounded-xl border border-(--crit-border)"
        loading="lazy"
      />
      <img
        src="/images/screenshots/ai-loop-light.png"
        alt="Crit reviewing a plan: inline comments, agent replies, and round-2 diff"
        class="logo-light w-full rounded-xl border border-(--crit-border)"
        loading="lazy"
      />
    </figure>
  </section>

  <%!-- ===== Primary feature: Plans + code ===== --%>
  <section class="max-w-7xl mx-auto mt-16 px-10 max-sm:px-4 max-sm:mt-16 w-full">
    <div class="max-w-[640px] mb-8 max-sm:mb-6">
      <h3 class="text-3xl font-extrabold tracking-tight mb-3 max-sm:text-2xl text-balance">
        Works great for plans and code.
      </h3>
      <p class="text-lg text-(--crit-fg-secondary) leading-relaxed max-sm:text-base">
        Beautifully rendered markdown. Source files render with syntax highlighting. Same review UI for both - you don't switch tools mid-feature.
      </p>
    </div>
    <div class="grid grid-cols-2 gap-5 max-md:grid-cols-1">
      <figure class="not-prose">
        <img
          src="/images/screenshots/plan-dark.png"
          alt="Reviewing a Markdown plan in Crit"
          class="logo-dark w-full rounded-xl border border-(--crit-border)"
          loading="lazy"
        />
        <img
          src="/images/screenshots/plan-light.png"
          alt="Reviewing a Markdown plan in Crit"
          class="logo-light w-full rounded-xl border border-(--crit-border)"
          loading="lazy"
        />
      </figure>
      <figure class="not-prose">
        <img
          src="/images/screenshots/code-dark.png"
          alt="Reviewing a syntax-highlighted source file in Crit"
          class="logo-dark w-full rounded-xl border border-(--crit-border)"
          loading="lazy"
        />
        <img
          src="/images/screenshots/code-light.png"
          alt="Reviewing a syntax-highlighted source file in Crit"
          class="logo-light w-full rounded-xl border border-(--crit-border)"
          loading="lazy"
        />
      </figure>
    </div>
  </section>

  <%!-- ===== Primary feature: Share reviews ===== --%>
  <section class="max-w-7xl mx-auto mt-16 px-10 max-sm:px-4 max-sm:mt-16 w-full">
    <div class="max-w-[640px] mb-8 max-sm:mb-6">
      <h3 class="text-3xl font-extrabold tracking-tight mb-3 max-sm:text-2xl text-balance">
        Share reviews for a second opinion.
      </h3>
      <p class="text-lg text-(--crit-fg-secondary) leading-relaxed max-sm:text-base">
        One click generates a public link &mdash; no install, no login on the other end.
        When finished, continue locally with your agent.
        <a href={~p"/features/share-reviews"} class="crit-link">Read more &rarr;</a>
      </p>
    </div>
    <figure class="not-prose">
      <img
        src="/images/screenshots/share-dark.png"
        alt="A shared Crit review with multi-author comment threads"
        class="logo-dark w-full rounded-xl border border-(--crit-border)"
        loading="lazy"
      />
      <img
        src="/images/screenshots/share-light.png"
        alt="A shared Crit review with multi-author comment threads"
        class="logo-light w-full rounded-xl border border-(--crit-border)"
        loading="lazy"
      />
    </figure>
  </section>

  <%!-- ===== Secondary features: 3-up ===== --%>
  <section class="max-w-7xl mx-auto mt-16 px-10 max-sm:px-4 max-sm:mt-16 w-full">
    <div class="grid grid-cols-3 gap-5 max-md:grid-cols-1">
      <div class="relative overflow-hidden border border-(--crit-border) rounded-lg bg-(--crit-bg-card) p-6 flex flex-col gap-3">
        <div
          class="pointer-events-none absolute -top-4 -right-4 w-44 h-44 opacity-15 grayscale"
          aria-hidden="true"
        >
          <%= for {file, top, left, size, rot} <- [
            {"claude-code", "8px", "92px", "44px", "-12deg"},
            {"cursor", "44px", "44px", "36px", "8deg"},
            {"github-copilot", "12px", "32px", "32px", "16deg"},
            {"codex", "76px", "92px", "32px", "-6deg"},
            {"windsurf", "80px", "20px", "28px", "20deg"},
            {"opencode", "112px", "60px", "30px", "-18deg"}
          ] do %>
            <img
              src={"/images/integrations/#{file}-dark.svg"}
              alt=""
              class="logo-dark absolute object-contain"
              style={"top: #{top}; left: #{left}; width: #{size}; height: #{size}; transform: rotate(#{rot});"}
              loading="lazy"
            />
            <img
              src={"/images/integrations/#{file}-light.svg"}
              alt=""
              class="logo-light absolute object-contain"
              style={"top: #{top}; left: #{left}; width: #{size}; height: #{size}; transform: rotate(#{rot});"}
              loading="lazy"
            />
          <% end %>
        </div>
        <h4 class="relative text-base font-semibold tracking-tight">Works with every agent</h4>
        <p class="relative text-sm text-(--crit-fg-secondary) leading-relaxed flex-1">
          Claude Code, Cursor, Copilot, Aider, Cline, Windsurf, or anything that reads
          files. One command sets up the skill so it can launch Crit and listen for
          feedback.
        </p>
        <a
          href={~p"/integrations"}
          class="relative text-xs text-(--crit-brand) mt-1 no-underline hover:underline"
        >
          Browse integrations &rarr;
        </a>
      </div>
      <div class="border border-(--crit-border) rounded-lg bg-(--crit-bg-card) p-6 flex flex-col gap-3">
        <h4 class="text-base font-semibold tracking-tight">Multi-round &amp; concurrent</h4>
        <p class="text-sm text-(--crit-fg-secondary) leading-relaxed flex-1">
          Iterate over multiple rounds of feedback per file. Run several reviews in
          parallel without them stepping on each other &mdash; useful when you're juggling
          a few agents at once.
        </p>
      </div>
      <div class="border border-(--crit-border) rounded-lg bg-(--crit-bg-card) p-6 flex flex-col gap-3">
        <h4 class="text-base font-semibold tracking-tight">Local-first, optionally shared</h4>
        <p class="text-sm text-(--crit-fg-secondary) leading-relaxed flex-1">
          Reviews live on your machine until you choose to share. Skip sharing entirely or
          self-host the share target on your own infra. No account required.
        </p>
        <a
          href={~p"/self-hosting"}
          class="text-xs text-(--crit-brand) mt-1 no-underline hover:underline"
        >
          Self-host crit-web &rarr;
        </a>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto my-12 px-10 max-sm:px-4 w-full">
    <h4 class="text-xs font-mono tracking-widest uppercase text-(--crit-fg-muted) mb-5">
      Plus the small stuff that adds up
    </h4>
    <ul class="flex flex-wrap gap-2 list-none p-0 m-0">
      <li class="feat-pill">Vim keybindings</li>
      <li class="feat-pill">Git diffs (split &amp; unified)</li>
      <li class="feat-pill">Round-over-round diffs</li>
      <li class="feat-pill">Syntax highlighting (190+ langs)</li>
      <li class="feat-pill">Mermaid diagrams</li>
      <li class="feat-pill">Table of contents</li>
      <li class="feat-pill">Dark &amp; light themes</li>
      <li class="feat-pill">Draft autosave</li>
      <li class="feat-pill">Insert suggestions</li>
      <li class="feat-pill">Single binary install</li>
    </ul>
  </section>

  <%!-- ===== Founder ===== --%>
  <section
    class="max-w-3xl mx-auto mt-12 px-10 max-sm:px-4 w-full"
    id="built-by"
  >
    <h2 class="text-3xl font-extrabold tracking-tight mb-8 max-sm:text-2xl text-balance">
      Built by people who review <span class="text-(--crit-brand)">a lot</span>
      of AI output<span class="text-(--crit-brand)">.</span>
    </h2>
    <div class="flex gap-8 items-start max-sm:flex-col max-sm:gap-5">
      <img
        src="/images/founder/photo.jpg"
        alt="Tomasz's photo"
        class="size-32 shrink-0 rounded-full object-cover bg-(--crit-bg-card)"
        loading="lazy"
        width="128"
        height="128"
      />
      <div class="flex-1 min-w-0">
        <h3 class="text-base font-semibold tracking-tight mb-2">
          Hey, I'm <span class="text-(--crit-brand)">Tomasz</span>!
        </h3>
        <p class="leading-relaxed mb-3">
          I've been building software for over 25 years. AI changed what it means to write code, but reviewing the output is harder than writing it yourself - agents produce plausible-looking diffs faster than you can read them carefully.
        </p>
        <p class="leading-relaxed mb-3">
          I built <strong>Crit</strong>
          to make careful review the easy path again. It now improves every week from the feedback of engineers who live in this loop.
        </p>
        <p class="text-sm text-(--crit-fg-secondary) leading-relaxed"></p>
        <div class="flex flex-wrap gap-x-4 gap-y-1 mt-4 text-xs text-(--crit-fg-muted)">
          <a
            href="https://github.com/tomasz-tomczyk"
            class="crit-link no-underline hover:underline"
          >
            GitHub
          </a>
          <a href="https://x.com/tomasztomczyk" class="crit-link no-underline hover:underline">
            Twitter
          </a>
        </div>
      </div>
    </div>
  </section>

  <%!-- ===== Testimonials ===== --%>
  <section class="max-w-7xl mx-auto mt-28 mb-20 px-10 max-sm:px-4 max-sm:mt-16 w-full">
    <div class="grid grid-cols-2 gap-8 max-sm:grid-cols-1 max-sm:gap-6" id="testimonials-grid">
      <div
        :for={testimonial <- @testimonials}
        data-reveal
        class="opacity-0 translate-y-4 transition-[opacity,transform] duration-500 ease-out data-[revealed]:opacity-100 data-[revealed]:translate-y-0"
      >
        <p class="text-lg font-semibold leading-snug text-(--crit-fg-primary) mb-4">
          {testimonial.highlight}
        </p>
        <div class="space-y-2 mb-4">
          <p
            :for={paragraph <- testimonial.body}
            class="leading-relaxed text-(--crit-fg-secondary)"
          >
            {paragraph}
          </p>
        </div>
        <div class="flex items-center gap-3">
          <img
            src={testimonial.avatar}
            alt={testimonial.author}
            class="size-9 rounded-full bg-(--crit-bg-elevated) shrink-0"
            loading="lazy"
            width="36"
            height="36"
          />
          <p class="font-mono text-xs text-(--crit-fg-muted) leading-snug min-w-0">
            <a
              href={testimonial.link}
              class="text-(--crit-fg-secondary) hover:text-(--crit-brand) transition-colors no-underline"
              target="_blank"
              rel="noopener noreferrer"
            >
              {testimonial.author}
            </a>
            <br />{testimonial.role}
          </p>
        </div>
      </div>
    </div>
  </section>

  <%!-- ===== Platform Stats ===== --%>
  <section
    class="max-w-7xl mx-auto w-full px-10 py-16 border-t border-(--crit-border) max-sm:px-4 max-sm:py-12"
    id="platform-stats"
  >
    <div class="max-w-2xl mx-auto text-center">
      <p class="font-mono text-xs uppercase tracking-[0.18em] text-(--crit-fg-muted) mb-5 flex items-center justify-center gap-3">
        <span class="inline-flex items-center gap-1.5">
          Shared to {CritWeb.Endpoint.host()}
        </span>
      </p>
      <p
        phx-no-format
        class="stats-paragraph text-lg leading-relaxed text-(--crit-fg-primary) text-balance max-sm:text-base"
      >So far, <span class="stat-num font-mono font-semibold text-(--crit-brand) tabular-nums" data-count-to={@stats.reviews_created}>{format_stat(@stats.reviews_created)}</span> shared reviews with <span class="stat-num font-mono font-semibold text-(--crit-brand) tabular-nums" data-count-to={@stats.comments_created}>{format_stat(@stats.comments_created)}</span> inline comments across <span class="stat-num font-mono font-semibold text-(--crit-brand) tabular-nums" data-count-to={@stats.lines_reviewed}>{format_stat(@stats.lines_reviewed)}</span> lines of code &mdash; roughly <span class="stat-num font-mono font-semibold text-(--crit-brand) tabular-nums" data-count-bytes={@stats.bytes_stored}>{format_bytes(@stats.bytes_stored)}</span> of plans, diffs, and prose.</p>
    </div>
  </section>
</div>
